---
type Props = {
  username: string;
  avatarUrl?: string | null;
  size?: number;
  class?: string;
  alt?: string;
  loading?: 'lazy' | 'eager';
  decoding?: 'async' | 'auto' | 'sync';
  width?: number;
  height?: number;
};

const {
  username,
  avatarUrl = null,
  size = 64,
  class: className = '',
  alt = `@${username} avatar`,
  loading = 'lazy',
  decoding = 'async',
  width,
  height
} = Astro.props as Props;

const src = avatarUrl ?? `https://github.com/${username}.png?size=${size}`;
const classes = ['avatar', className].filter(Boolean).join(' ');
---
<img
  class={classes}
  src={src}
  alt={alt}
  loading={loading}
  decoding={decoding}
  width={width}
  height={height}
/>
