---
type QuickContributeMode = 'edit' | 'create';

type Props = {
  mode: QuickContributeMode;
  title: string;
  description: string;
  fixedFilePath?: string;
  initialCategory?: string;
  initialPostSlug?: string;
  initialContent?: string;
  initialPrTitle?: string;
  initialPrBody?: string;
  submitLabel?: string;
};

const {
  mode,
  title,
  description,
  fixedFilePath,
  initialCategory = '',
  initialPostSlug = '',
  initialContent = '',
  initialPrTitle = '',
  initialPrBody = '',
  submitLabel = 'Create pull request'
} = Astro.props as Props;

const configuredAuthWorkerUrl = (import.meta.env.PUBLIC_GITHUB_AUTH_WORKER_URL ?? '').trim();
const authWorkerBaseUrl = (() => {
  if (!configuredAuthWorkerUrl) return '';
  try {
    const parsed = new URL(configuredAuthWorkerUrl);
    const normalizedPath = parsed.pathname.replace(/\/+$/, '');
    return `${parsed.origin}${normalizedPath}`;
  } catch {
    return '';
  }
})();

const normalizedMode: QuickContributeMode = mode === 'create' ? 'create' : 'edit';
const resolvedFixedFilePath = normalizedMode === 'edit' ? fixedFilePath ?? '' : '';
---
<section
  class="card quick-contribute"
  data-quick-contribute
  data-mode={normalizedMode}
  data-fixed-file-path={resolvedFixedFilePath}
  data-auth-worker-base={authWorkerBaseUrl}
>
  <h2 class="icon-label"><i class="ti ti-pencil-plus icon-sm" aria-hidden="true"></i>{title}</h2>
  <p class="meta">{description}</p>

  <form class="quick-contribute-form" data-quick-contribute-form>
    {normalizedMode === 'create' ? (
      <div class="quick-contribute-grid">
        <label class="quick-contribute-field">
          <span class="quick-contribute-field-head">
            <span>Category</span>
            <button
              type="button"
              class="quick-contribute-help-trigger"
              data-help-trigger
              data-help-title="Category"
              data-help-body="Use lowercase with hyphens, for example: networking, security, database."
              aria-label="Category hint"
            >?</button>
          </span>
          <input
            type="text"
            name="category"
            placeholder="networking"
            autocomplete="off"
            value={initialCategory}
            required
          />
        </label>

        <label class="quick-contribute-field">
          <span class="quick-contribute-field-head">
            <span>Post slug</span>
            <button
              type="button"
              class="quick-contribute-help-trigger"
              data-help-trigger
              data-help-title="Post slug"
              data-help-body="Use lowercase with hyphens only, for example: how-dns-works. Do not include .md."
              aria-label="Post slug hint"
            >?</button>
          </span>
          <input
            type="text"
            name="postSlug"
            placeholder="how-dns-works"
            autocomplete="off"
            value={initialPostSlug}
            required
          />
        </label>
      </div>
    ) : null}

    <p class="meta quick-contribute-target">
      <span class="quick-contribute-field-head">
        <span>Target file</span>
        <button
          type="button"
          class="quick-contribute-help-trigger"
          data-help-trigger
          data-help-title="Target file"
          data-help-body="Final markdown path in the repository. It must stay under content/posts/<category>/<post>.md."
          aria-label="Target file hint"
        >?</button>
      </span>
      <code data-quick-contribute-target-code>{resolvedFixedFilePath || 'content/posts/<category>/<slug>.md'}</code>
    </p>

    <p class="meta quick-contribute-post-url">
      <span class="quick-contribute-field-head">
        <span>Post URL</span>
        <button
          type="button"
          class="quick-contribute-help-trigger"
          data-help-trigger
          data-help-title="Post URL"
          data-help-body="Computed from category and post slug in create mode, or from the fixed target file in edit mode."
          aria-label="Post URL hint"
        >?</button>
      </span>
      <code data-quick-post-url-label>https://openblog.cc/posts/&lt;category&gt;/&lt;slug&gt;</code>
    </p>

    <label class="quick-contribute-field">
      <span class="quick-contribute-field-head">
        <span>Title</span>
        <button
          type="button"
          class="quick-contribute-help-trigger"
          data-help-trigger
          data-help-title="Title"
          data-help-body="Post title in frontmatter. Keep it specific and outcome-focused."
          aria-label="Title hint"
        >?</button>
      </span>
      <input type="text" name="postTitle" placeholder="How DNS resolution works in practice" autocomplete="off" required />
    </label>

    <label class="quick-contribute-field">
      <span class="quick-contribute-field-head">
        <span>Description</span>
        <button
          type="button"
          class="quick-contribute-help-trigger"
          data-help-trigger
          data-help-title="Description"
          data-help-body="One concise sentence for readers and metadata snippets."
          aria-label="Description hint"
        >?</button>
      </span>
      <textarea name="postDescription" rows={3} placeholder="Explain what readers will learn and why it matters." required></textarea>
    </label>

    <label class="quick-contribute-field">
      <span class="quick-contribute-field-head">
        <span>Thumbnail URL</span>
        <button
          type="button"
          class="quick-contribute-help-trigger"
          data-help-trigger
          data-help-title="Thumbnail URL"
          data-help-body="Public image URL for post cards and social previews."
          aria-label="Thumbnail URL hint"
        >?</button>
      </span>
      <input
        type="text"
        name="thumbnailUrl"
        placeholder="https://images.example.com/dns-cover.jpg"
        autocomplete="off"
      />
    </label>

    <section class="quick-contribute-thumbnail-preview" aria-label="Post card preview">
      <div class="quick-contribute-preview-head">
        <strong class="icon-label"><i class="ti ti-photo icon-sm" aria-hidden="true"></i>Thumbnail preview</strong>
      </div>
      <div class="quick-contribute-thumbnail-card">
        <div class="quick-contribute-thumbnail-media">
          <img class="quick-contribute-thumbnail-image" data-quick-thumbnail-image alt="" loading="lazy" decoding="async" hidden />
          <p class="meta quick-contribute-thumbnail-empty" data-quick-thumbnail-empty>
            Set a thumbnail URL to preview the post card image.
          </p>
        </div>
        <div class="quick-contribute-thumbnail-copy">
          <p class="quick-contribute-thumbnail-url">
            <code data-quick-post-url-text>https://openblog.cc/posts/&lt;category&gt;/&lt;slug&gt;</code>
          </p>
          <strong class="quick-contribute-thumbnail-title" data-quick-thumbnail-title-preview>Post title preview</strong>
          <p class="meta quick-contribute-thumbnail-description" data-quick-thumbnail-description-preview>
            Post description preview will appear from frontmatter.
          </p>
        </div>
      </div>
    </section>

    <label class="quick-contribute-field">
      <span class="quick-contribute-field-head">
        <span>Tags</span>
        <button
          type="button"
          class="quick-contribute-help-trigger"
          data-help-trigger
          data-help-title="Tags"
          data-help-body="Comma-separated tags. Example: networking, dns, troubleshooting."
          aria-label="Tags hint"
        >?</button>
      </span>
      <input type="text" name="postTags" placeholder="networking, dns, troubleshooting" autocomplete="off" />
      <div class="quick-contribute-tags-preview" data-quick-tags-preview hidden></div>
    </label>

    <label class="quick-contribute-field">
      <span class="quick-contribute-field-head">
        <span>Content</span>
        <button
          type="button"
          class="quick-contribute-help-trigger"
          data-help-trigger
          data-help-title="Content"
          data-help-body="Write markdown body content. Frontmatter is synced from the fields above."
          aria-label="Content hint"
        >?</button>
      </span>
      <textarea name="content" rows={18} required>{initialContent}</textarea>
    </label>

    <label class="quick-contribute-field">
      <span class="quick-contribute-field-head">
        <span>PR title</span>
        <button
          type="button"
          class="quick-contribute-help-trigger"
          data-help-trigger
          data-help-title="PR title"
          data-help-body="Use a clear action title, for example: Improve DNS guide references and examples."
          aria-label="PR title hint"
        >?</button>
      </span>
      <input type="text" name="prTitle" value={initialPrTitle} placeholder="Improve article clarity and examples" maxlength="120" required />
    </label>

    <label class="quick-contribute-field">
      <span class="quick-contribute-field-head">
        <span>PR summary</span>
        <button
          type="button"
          class="quick-contribute-help-trigger"
          data-help-trigger
          data-help-title="PR summary"
          data-help-body="Describe what changed, why it is better, and which post slug is affected."
          aria-label="PR summary hint"
        >?</button>
      </span>
      <textarea name="prBody" rows={5} placeholder="What changed and why it is better.">{initialPrBody}</textarea>
    </label>

    <div class="quick-contribute-actions">
      <a class="contribute-action" data-quick-contribute-login href="#" hidden>
        <i class="ti ti-brand-github icon-sm" aria-hidden="true"></i>
        Sign in with GitHub
      </a>
      <button class="contribute-action quick-contribute-submit" type="submit" data-quick-contribute-submit>
        <i class="ti ti-git-pull-request icon-sm" aria-hidden="true"></i>
        {submitLabel}
      </button>
      <a class="contribute-action" data-quick-contribute-pr href="#" target="_blank" rel="noopener noreferrer" hidden>
        <i class="ti ti-external-link icon-sm" aria-hidden="true"></i>
        Open created PR
      </a>
    </div>

    <p class="meta quick-contribute-status" data-quick-contribute-status role="status" aria-live="polite"></p>

    <section class="quick-contribute-preview" aria-label="Live preview">
      <div class="quick-contribute-preview-head">
        <strong class="icon-label"><i class="ti ti-eye icon-sm" aria-hidden="true"></i>Live preview</strong>
      </div>
      <p class="meta quick-contribute-preview-empty" data-quick-preview-empty>Start typing to see a rendered markdown preview.</p>
      <div class="article-content quick-contribute-preview-body" data-quick-preview hidden></div>
    </section>
  </form>

  <div class="quick-contribute-help-modal" data-help-modal hidden>
    <button
      type="button"
      class="quick-contribute-help-backdrop"
      data-help-close
      aria-label="Close field hint popup"
    />
    <div class="quick-contribute-help-panel" role="dialog" aria-modal="true" aria-label="Field hints">
      <div class="quick-contribute-help-header">
        <strong data-help-title-text>Field hint</strong>
        <button type="button" class="quick-contribute-help-close" data-help-close aria-label="Close hint">
          <i class="ti ti-x icon-sm" aria-hidden="true"></i>
        </button>
      </div>
      <p class="meta quick-contribute-help-text" data-help-body-text></p>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var escapeHtml = function (value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    };

    var formatInline = function (value) {
      return value
        .replace(/\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>')
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
    };

    var stripFrontmatter = function (source) {
      var normalized = String(source || '').replace(/\r\n/g, '\n');
      return normalized.replace(/^---\n[\s\S]*?\n(?:---|\.\.\.)\n?/, '');
    };

    var renderMarkdownPreview = function (source) {
      var lines = stripFrontmatter(source).split('\n');
      var parts = [];
      var inCode = false;
      var inList = false;
      var codeBuffer = [];

      var flushList = function () {
        if (!inList) return;
        parts.push('</ul>');
        inList = false;
      };

      for (var index = 0; index < lines.length; index += 1) {
        var rawLine = lines[index];
        var line = escapeHtml(rawLine);

        if (line.trim().startsWith('```')) {
          if (inCode) {
            parts.push('<pre><code>' + codeBuffer.join('\n') + '</code></pre>');
            codeBuffer = [];
            inCode = false;
          } else {
            flushList();
            inCode = true;
          }
          continue;
        }

        if (inCode) {
          codeBuffer.push(line);
          continue;
        }

        var listMatch = line.match(/^\s*[-*]\s+(.+)$/);
        if (listMatch) {
          if (!inList) {
            parts.push('<ul>');
            inList = true;
          }
          parts.push('<li>' + formatInline(listMatch[1]) + '</li>');
          continue;
        }

        flushList();

        if (!line.trim()) {
          continue;
        }

        var h3 = line.match(/^###\s+(.+)$/);
        if (h3) {
          parts.push('<h3>' + formatInline(h3[1]) + '</h3>');
          continue;
        }

        var h2 = line.match(/^##\s+(.+)$/);
        if (h2) {
          parts.push('<h2>' + formatInline(h2[1]) + '</h2>');
          continue;
        }

        var h1 = line.match(/^#\s+(.+)$/);
        if (h1) {
          parts.push('<h1>' + formatInline(h1[1]) + '</h1>');
          continue;
        }

        var quote = line.match(/^&gt;\s+(.+)$/);
        if (quote) {
          parts.push('<blockquote><p>' + formatInline(quote[1]) + '</p></blockquote>');
          continue;
        }

        parts.push('<p>' + formatInline(line) + '</p>');
      }

      if (inCode) {
        parts.push('<pre><code>' + codeBuffer.join('\n') + '</code></pre>');
      }
      if (inList) {
        parts.push('</ul>');
      }

      return parts.join('');
    };

    var toYamlDoubleQuotedValue = function (value) {
      return '"' + String(value || '')
        .replace(/\\/g, '\\\\')
        .replace(/"/g, '\\"') + '"';
    };

    var toYamlSingleQuotedValue = function (value) {
      return "'" + String(value || '').replace(/'/g, "''") + "'";
    };

    var titleNeedsQuotes = function (value) {
      var text = String(value || '');
      return (
        !text ||
        /:\s/.test(text) ||
        /^\s|\s$/.test(text) ||
        /^[\-?:,[\]{}#&*!|>'"%@`]/.test(text)
      );
    };

    var toYamlTitleValue = function (value, preserveSingleQuotes, preserveDoubleQuotes) {
      var text = String(value || '');
      var shouldQuote = titleNeedsQuotes(text);

      if (!shouldQuote) {
        return text;
      }

      if (preserveSingleQuotes) {
        return toYamlSingleQuotedValue(text);
      }

      if (preserveDoubleQuotes) {
        return toYamlDoubleQuotedValue(text);
      }

      return toYamlDoubleQuotedValue(text);
    };

    var syncFrontmatterTitle = function (content, nextTitle) {
      var source = String(content || '');
      var trimmedTitle = String(nextTitle || '').trim();
      if (!trimmedTitle) return source;

      var frontmatterMatch = source.match(/^---\r?\n[\s\S]*?\r?\n(?:---|\.\.\.)\r?\n?/);
      if (!frontmatterMatch) return source;

      var frontmatterBlock = frontmatterMatch[0];
      var existingTitleMatch = frontmatterBlock.match(/^title:\s*(.*)$/m);
      var existingTitleRaw = existingTitleMatch ? existingTitleMatch[1].trim() : '';
      var preserveSingleQuotes = /^'[\s\S]*'$/.test(existingTitleRaw);
      var preserveDoubleQuotes = /^"[\s\S]*"$/.test(existingTitleRaw);
      var titleLine = 'title: ' + toYamlTitleValue(trimmedTitle, preserveSingleQuotes, preserveDoubleQuotes);
      var updatedFrontmatter = '';

      if (/^title:\s*.*$/m.test(frontmatterBlock)) {
        updatedFrontmatter = frontmatterBlock.replace(/^title:\s*.*$/m, titleLine);
      } else {
        updatedFrontmatter = frontmatterBlock.replace(/^---\r?\n/, function (start) {
          return start + titleLine + '\n';
        });
      }

      return updatedFrontmatter + source.slice(frontmatterBlock.length);
    };

    var escapeRegExp = function (value) {
      return String(value || '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    };

    var stripWrappingQuotes = function (value) {
      var text = String(value || '').trim();
      if (!text) return '';

      if (/^".*"$/.test(text)) {
        return text.slice(1, -1).replace(/\\"/g, '"').replace(/\\\\/g, '\\');
      }
      if (/^'.*'$/.test(text)) {
        return text.slice(1, -1).replace(/''/g, "'");
      }
      return text;
    };

    var readFrontmatterField = function (content, fieldName) {
      var source = String(content || '');
      var frontmatterMatch = source.match(/^---\r?\n([\s\S]*?)\r?\n(?:---|\.\.\.)\r?\n?/);
      if (!frontmatterMatch) return '';

      var frontmatterBody = frontmatterMatch[1];
      var pattern = new RegExp('^' + escapeRegExp(fieldName) + ':\\s*(.*)$', 'm');
      var fieldMatch = frontmatterBody.match(pattern);
      if (!fieldMatch) return '';
      return stripWrappingQuotes(fieldMatch[1]);
    };

    var toYamlFieldValue = function (value) {
      var text = String(value || '').trim();
      if (!text) return '';
      if (/[:#\r\n]/.test(text) || /^\s|\s$/.test(text)) {
        return toYamlDoubleQuotedValue(text);
      }
      return text;
    };

    var syncFrontmatterField = function (content, fieldName, nextValue) {
      var source = String(content || '');
      var frontmatterMatch = source.match(/^---\r?\n([\s\S]*?)\r?\n(---|\.\.\.)\r?\n?/);
      if (!frontmatterMatch) return source;

      var frontmatterBody = frontmatterMatch[1];
      var closingDelimiter = frontmatterMatch[2];
      var lineEnding = source.indexOf('\r\n') >= 0 ? '\r\n' : '\n';
      var pattern = new RegExp('^' + escapeRegExp(fieldName) + ':\\s*.*$');
      var value = String(nextValue || '').trim();
      var lines = frontmatterBody.split(/\r?\n/);
      var updatedLines = [];
      var found = false;

      for (var index = 0; index < lines.length; index += 1) {
        var line = lines[index];
        if (pattern.test(line)) {
          found = true;
          if (value) {
            updatedLines.push(fieldName + ': ' + toYamlFieldValue(value));
          }
          continue;
        }
        updatedLines.push(line);
      }

      if (value && !found) {
        updatedLines.push(fieldName + ': ' + toYamlFieldValue(value));
      }

      var updatedFrontmatter = '---' + lineEnding + updatedLines.join(lineEnding) + lineEnding + closingDelimiter + lineEnding;
      return updatedFrontmatter + source.slice(frontmatterMatch[0].length);
    };

    var toTagList = function (value) {
      var items = String(value || '')
        .split(',')
        .map(function (entry) { return entry.trim(); })
        .filter(Boolean);
      var deduped = [];
      for (var i = 0; i < items.length; i += 1) {
        if (deduped.indexOf(items[i]) === -1) {
          deduped.push(items[i]);
        }
      }
      return deduped;
    };

    var readFrontmatterTags = function (content) {
      var source = String(content || '');
      var frontmatterMatch = source.match(/^---\r?\n([\s\S]*?)\r?\n(?:---|\.\.\.)\r?\n?/);
      if (!frontmatterMatch) return '';
      var frontmatterBody = frontmatterMatch[1];

      var listMatch = frontmatterBody.match(/^tags:\s*\r?\n((?:\s*-\s*.*(?:\r?\n|$))*)/m);
      if (listMatch && listMatch[1]) {
        var listTags = [];
        var itemPattern = /^\s*-\s*(.+)\s*$/gm;
        var item = null;
        while ((item = itemPattern.exec(listMatch[1])) !== null) {
          var parsedTag = stripWrappingQuotes(item[1]);
          if (parsedTag) listTags.push(parsedTag);
        }
        if (listTags.length > 0) return listTags.join(', ');
      }

      var singleMatch = frontmatterBody.match(/^tags:\s*(.+)$/m);
      if (!singleMatch) return '';
      var singleValue = stripWrappingQuotes(singleMatch[1]);
      if (!singleValue) return '';
      return toTagList(singleValue).join(', ');
    };

    var syncFrontmatterTags = function (content, nextTags) {
      var source = String(content || '');
      var frontmatterMatch = source.match(/^---\r?\n([\s\S]*?)\r?\n(---|\.\.\.)\r?\n?/);
      if (!frontmatterMatch) return source;

      var frontmatterBody = frontmatterMatch[1];
      var closingDelimiter = frontmatterMatch[2];
      var lineEnding = source.indexOf('\r\n') >= 0 ? '\r\n' : '\n';
      var lines = frontmatterBody.split(/\r?\n/);
      var tags = toTagList(nextTags);

      var tagsStart = -1;
      var tagsEnd = -1;
      for (var index = 0; index < lines.length; index += 1) {
        var tagHeader = lines[index].match(/^tags:\s*(.*)$/);
        if (!tagHeader) continue;
        tagsStart = index;
        tagsEnd = index;
        if (!tagHeader[1].trim()) {
          while (tagsEnd + 1 < lines.length && /^\s*-\s+/.test(lines[tagsEnd + 1])) {
            tagsEnd += 1;
          }
        }
        break;
      }

      if (tagsStart >= 0) {
        lines.splice(tagsStart, tagsEnd - tagsStart + 1);
      }

      if (tags.length > 0) {
        var insertAt = tagsStart >= 0 ? tagsStart : lines.length;
        lines.splice(insertAt, 0, 'tags: ' + tags.join(', '));
      }

      var updatedFrontmatter = '---' + lineEnding + lines.join(lineEnding) + lineEnding + closingDelimiter + lineEnding;
      return updatedFrontmatter + source.slice(frontmatterMatch[0].length);
    };

    var toPostUrlFromParts = function (category, postSlug) {
      var normalizedCategory = slugifySegment(category);
      var normalizedPostSlug = slugifySegment(postSlug);
      if (!normalizedCategory || !normalizedPostSlug) return '';
      return '/posts/' + encodeURIComponent(normalizedCategory) + '/' + encodeURIComponent(normalizedPostSlug);
    };

    var getPostUrlFromFilePath = function (filePath) {
      var normalizedPath = String(filePath || '').trim().replace(/\\/g, '/');
      var match = normalizedPath.match(/^content\/posts\/([^/]+)\/([^/]+)\.md$/);
      if (!match) return '';
      return '/posts/' + encodeURIComponent(match[1]) + '/' + encodeURIComponent(match[2]);
    };

    var getPreviewMetaFromContent = function (content, fallbackTitle) {
      var title = readFrontmatterField(content, 'title') || String(fallbackTitle || '').trim() || 'Post title preview';
      var description = readFrontmatterField(content, 'description');
      var thumbnail = readFrontmatterField(content, 'thumbnail');
      var thumbnailAlt = readFrontmatterField(content, 'thumbnailAlt');

      return {
        title: title,
        description: description,
        thumbnail: thumbnail,
        thumbnailAlt: thumbnailAlt
      };
    };

    var slugifySegment = function (value) {
      return String(value || '')
        .trim()
        .toLowerCase()
        .replace(/[\s_]+/g, '-')
        .replace(/[^a-z0-9-]+/g, '-')
        .replace(/-{2,}/g, '-')
        .replace(/^-+|-+$/g, '');
    };

    var setStatus = function (statusEl, message, kind) {
      if (!statusEl) return;
      statusEl.textContent = message || '';
      statusEl.classList.remove('is-success', 'is-error', 'is-info');
      if (!message) return;
      if (kind === 'success') statusEl.classList.add('is-success');
      else if (kind === 'error') statusEl.classList.add('is-error');
      else statusEl.classList.add('is-info');
    };

    var updateTargetFilePath = function (form, root) {
      var mode = root.getAttribute('data-mode') === 'create' ? 'create' : 'edit';
      var fixedFilePath = root.getAttribute('data-fixed-file-path') || '';
      var targetCode = form.querySelector('[data-quick-contribute-target-code]');
      if (!(targetCode instanceof HTMLElement)) return '';

      if (mode === 'edit') {
        targetCode.textContent = fixedFilePath;
        return fixedFilePath;
      }

      var categoryInput = form.elements.namedItem('category');
      var postSlugInput = form.elements.namedItem('postSlug');
      var category = categoryInput instanceof HTMLInputElement ? slugifySegment(categoryInput.value) : '';
      var postSlug = postSlugInput instanceof HTMLInputElement ? slugifySegment(postSlugInput.value) : '';

      var filePath = category && postSlug ? 'content/posts/' + category + '/' + postSlug + '.md' : '';
      targetCode.textContent = filePath || 'content/posts/<category>/<slug>.md';

      return filePath;
    };

    var initializeForm = async function (root) {
      var authApiBase = root.getAttribute('data-auth-worker-base') || '';
      var toAuthUrl = function (path) {
        return authApiBase ? authApiBase + path : path;
      };
      var toLoginUrl = function () {
        var url = new URL(toAuthUrl('/login'), window.location.origin);
        url.searchParams.set('return_to', window.location.href);
        return url.toString();
      };

      var form = root.querySelector('[data-quick-contribute-form]');
      if (!(form instanceof HTMLFormElement)) return;
      if (form.getAttribute('data-ready') === 'true') return;
      form.setAttribute('data-ready', 'true');

      var submitButton = form.querySelector('[data-quick-contribute-submit]');
      var loginButton = form.querySelector('[data-quick-contribute-login]');
      var statusEl = form.querySelector('[data-quick-contribute-status]');
      var prLink = form.querySelector('[data-quick-contribute-pr]');
      var helpModal = root.querySelector('[data-help-modal]');
      var helpTitleText = root.querySelector('[data-help-title-text]');
      var helpBodyText = root.querySelector('[data-help-body-text]');
      var prTitleInput = form.elements.namedItem('prTitle');
      var contentInput = form.elements.namedItem('content');
      var postTitleInput = form.elements.namedItem('postTitle');
      var postDescriptionInput = form.elements.namedItem('postDescription');
      var thumbnailUrlInput = form.elements.namedItem('thumbnailUrl');
      var postTagsInput = form.elements.namedItem('postTags');
      var preview = form.querySelector('[data-quick-preview]');
      var previewEmpty = form.querySelector('[data-quick-preview-empty]');
      var thumbnailImage = form.querySelector('[data-quick-thumbnail-image]');
      var thumbnailEmpty = form.querySelector('[data-quick-thumbnail-empty]');
      var postUrlLabel = form.querySelector('[data-quick-post-url-label]');
      var postUrlText = form.querySelector('[data-quick-post-url-text]');
      var thumbnailTitlePreview = form.querySelector('[data-quick-thumbnail-title-preview]');
      var thumbnailDescriptionPreview = form.querySelector('[data-quick-thumbnail-description-preview]');
      var tagsPreview = form.querySelector('[data-quick-tags-preview]');

      if (!(submitButton instanceof HTMLButtonElement)) return;
      if (loginButton instanceof HTMLAnchorElement) {
        loginButton.href = toLoginUrl();
      }

      var currentUsername = '';
      var refreshTargetPath = function () {
        return updateTargetFilePath(form, root);
      };
      var getComputedPostPath = function () {
        var mode = root.getAttribute('data-mode') === 'create' ? 'create' : 'edit';
        if (mode === 'edit') {
          return getPostUrlFromFilePath(root.getAttribute('data-fixed-file-path') || '');
        }

        var categoryInput = form.elements.namedItem('category');
        var postSlugInput = form.elements.namedItem('postSlug');
        var category = categoryInput instanceof HTMLInputElement ? categoryInput.value : '';
        var postSlug = postSlugInput instanceof HTMLInputElement ? postSlugInput.value : '';
        return toPostUrlFromParts(category, postSlug);
      };
      var toFullPostUrl = function (pathValue) {
        var normalizedPath = String(pathValue || '').trim();
        if (!normalizedPath) return '';
        var origin = window.location.origin.replace(/\/+$/, '');
        if (normalizedPath.indexOf('<') >= 0) {
          return origin + normalizedPath;
        }
        try {
          return new URL(normalizedPath, window.location.origin).toString();
        } catch (_) {
          return origin + normalizedPath;
        }
      };
      var syncComputedPostUrl = function () {
        var computedPostPath = getComputedPostPath() || '/posts/<category>/<slug>';
        var fullPostUrl = toFullPostUrl(computedPostPath);
        if (postUrlLabel instanceof HTMLElement) {
          postUrlLabel.textContent = fullPostUrl;
        }
        if (postUrlText instanceof HTMLElement) {
          postUrlText.textContent = fullPostUrl;
        }
        return fullPostUrl;
      };
      var renderTagBadges = function () {
        if (!(postTagsInput instanceof HTMLInputElement)) return;
        if (!(tagsPreview instanceof HTMLElement)) return;
        var tags = toTagList(postTagsInput.value);
        tagsPreview.innerHTML = '';
        if (tags.length === 0) {
          tagsPreview.hidden = true;
          return;
        }

        tags.forEach(function (tag) {
          var badge = document.createElement('span');
          badge.className = 'post-chip-label post-tag-link icon-label quick-tag-chip';
          var icon = document.createElement('i');
          icon.className = 'ti ti-tag post-chip-icon';
          icon.setAttribute('aria-hidden', 'true');
          var text = document.createElement('span');
          text.textContent = tag;
          badge.appendChild(icon);
          badge.appendChild(text);
          tagsPreview.appendChild(badge);
        });
        tagsPreview.hidden = false;
      };
      var syncMetaInputsFromContent = function () {
        if (!(contentInput instanceof HTMLTextAreaElement)) return;
        if (postTitleInput instanceof HTMLInputElement) {
          var contentTitle = readFrontmatterField(contentInput.value, 'title');
          if (contentTitle && postTitleInput.value !== contentTitle) {
            postTitleInput.value = contentTitle;
          }
        }
        if (postDescriptionInput instanceof HTMLTextAreaElement) {
          var contentDescription = readFrontmatterField(contentInput.value, 'description');
          if (postDescriptionInput.value !== contentDescription) {
            postDescriptionInput.value = contentDescription;
          }
        }
        if (!(thumbnailUrlInput instanceof HTMLInputElement)) return;
        var thumbnailInFrontmatter = readFrontmatterField(contentInput.value, 'thumbnail');
        if (thumbnailUrlInput.value !== thumbnailInFrontmatter) {
          thumbnailUrlInput.value = thumbnailInFrontmatter;
        }
        if (postTagsInput instanceof HTMLInputElement) {
          var contentTags = readFrontmatterTags(contentInput.value);
          if (postTagsInput.value !== contentTags) {
            postTagsInput.value = contentTags;
          }
        }
        renderTagBadges();
      };
      var syncContentMetaFromInputs = function (sourceField) {
        if (!(contentInput instanceof HTMLTextAreaElement)) return;
        var nextContent = contentInput.value;
        if (sourceField === 'title' && postTitleInput instanceof HTMLInputElement) {
          nextContent = syncFrontmatterTitle(nextContent, postTitleInput.value);
        } else if (sourceField === 'description' && postDescriptionInput instanceof HTMLTextAreaElement) {
          nextContent = syncFrontmatterField(nextContent, 'description', postDescriptionInput.value);
        } else if (sourceField === 'thumbnail' && thumbnailUrlInput instanceof HTMLInputElement) {
          nextContent = syncFrontmatterField(nextContent, 'thumbnail', thumbnailUrlInput.value);
        } else if (sourceField === 'tags' && postTagsInput instanceof HTMLInputElement) {
          nextContent = syncFrontmatterTags(nextContent, postTagsInput.value);
        }
        if (nextContent !== contentInput.value) {
          contentInput.value = nextContent;
        }
      };
      var renderThumbnailPreview = function () {
        var source = contentInput instanceof HTMLTextAreaElement ? contentInput.value : '';
        var fallbackTitle = postTitleInput instanceof HTMLInputElement ? postTitleInput.value : '';
        var meta = getPreviewMetaFromContent(source, fallbackTitle);
        var thumbnailUrlFromInput = thumbnailUrlInput instanceof HTMLInputElement ? thumbnailUrlInput.value.trim() : '';
        var thumbnailUrl = thumbnailUrlFromInput || meta.thumbnail;
        var thumbnailAlt = meta.thumbnailAlt || meta.title || 'Post thumbnail preview';
        syncComputedPostUrl();
        if (thumbnailTitlePreview instanceof HTMLElement) {
          thumbnailTitlePreview.textContent = meta.title;
        }
        if (thumbnailDescriptionPreview instanceof HTMLElement) {
          thumbnailDescriptionPreview.textContent = meta.description || 'Post description preview will appear from frontmatter.';
        }
        if (!(thumbnailImage instanceof HTMLImageElement) || !(thumbnailEmpty instanceof HTMLElement)) {
          return;
        }

        if (!thumbnailUrl) {
          thumbnailImage.hidden = true;
          thumbnailImage.removeAttribute('src');
          thumbnailImage.removeAttribute('data-current-src');
          thumbnailEmpty.hidden = false;
          thumbnailEmpty.textContent = 'Set a thumbnail URL to preview the post card image.';
          return;
        }

        thumbnailImage.alt = thumbnailAlt;
        thumbnailImage.hidden = false;
        thumbnailEmpty.hidden = true;
        thumbnailEmpty.textContent = 'Set a thumbnail URL to preview the post card image.';
        var currentSrc = thumbnailImage.getAttribute('data-current-src') || '';
        if (currentSrc !== thumbnailUrl) {
          thumbnailImage.setAttribute('data-current-src', thumbnailUrl);
          thumbnailImage.src = thumbnailUrl;
        }
      };
      var renderPreview = function () {
        if (!(contentInput instanceof HTMLTextAreaElement)) return;
        if (!(preview instanceof HTMLElement)) return;
        if (!(previewEmpty instanceof HTMLElement)) return;

        var source = contentInput.value || '';
        if (!source.trim()) {
          preview.innerHTML = '';
          preview.hidden = true;
          previewEmpty.hidden = false;
          return;
        }

        var rendered = renderMarkdownPreview(source);
        if (!rendered.trim()) {
          preview.textContent = source;
        } else {
          preview.innerHTML = rendered;
        }
        preview.hidden = false;
        previewEmpty.hidden = true;
      };
      if (thumbnailImage instanceof HTMLImageElement && thumbnailEmpty instanceof HTMLElement) {
        thumbnailImage.addEventListener('load', function () {
          thumbnailImage.hidden = false;
          thumbnailEmpty.hidden = true;
          thumbnailEmpty.textContent = 'Set a thumbnail URL to preview the post card image.';
        });
        thumbnailImage.addEventListener('error', function () {
          thumbnailImage.hidden = true;
          thumbnailEmpty.hidden = false;
          thumbnailEmpty.textContent = 'Unable to load this image URL. Check the link and try again.';
        });
      }

      var openHelp = function (title, body) {
        if (!(helpModal instanceof HTMLElement)) return;
        if (helpTitleText instanceof HTMLElement) {
          helpTitleText.textContent = title || 'Field hint';
        }
        if (helpBodyText instanceof HTMLElement) {
          helpBodyText.textContent = body || '';
        }
        helpModal.hidden = false;
        helpModal.classList.add('is-open');
      };

      var closeHelp = function () {
        if (!(helpModal instanceof HTMLElement)) return;
        helpModal.classList.remove('is-open');
        helpModal.hidden = true;
      };

      if (helpModal instanceof HTMLElement) {
        var helpTriggers = Array.from(form.querySelectorAll('[data-help-trigger]'));
        helpTriggers.forEach(function (trigger) {
          if (!(trigger instanceof HTMLButtonElement)) return;
          trigger.addEventListener('click', function () {
            var title = trigger.getAttribute('data-help-title') || 'Field hint';
            var body = trigger.getAttribute('data-help-body') || '';
            openHelp(title, body);
          });
        });

        var helpCloseControls = Array.from(helpModal.querySelectorAll('[data-help-close]'));
        helpCloseControls.forEach(function (control) {
          if (!(control instanceof HTMLElement)) return;
          control.addEventListener('click', closeHelp);
        });

        document.addEventListener('keydown', function (event) {
          if (event.key === 'Escape' && !helpModal.hidden) {
            closeHelp();
          }
        });
      }

      refreshTargetPath();
      syncMetaInputsFromContent();
      syncComputedPostUrl();
      renderPreview();
      renderThumbnailPreview();

      var categoryInput = form.elements.namedItem('category');
      var postSlugInput = form.elements.namedItem('postSlug');
      var refreshPathAndPreview = function () {
        refreshTargetPath();
        syncComputedPostUrl();
        renderThumbnailPreview();
      };

      if (categoryInput instanceof HTMLInputElement) {
        categoryInput.addEventListener('input', refreshPathAndPreview);
      }
      if (postSlugInput instanceof HTMLInputElement) {
        postSlugInput.addEventListener('input', refreshPathAndPreview);
      }
      if (postTitleInput instanceof HTMLInputElement) {
        postTitleInput.addEventListener('input', function () {
          syncContentMetaFromInputs('title');
          renderPreview();
          renderThumbnailPreview();
        });
      }
      if (postDescriptionInput instanceof HTMLTextAreaElement) {
        postDescriptionInput.addEventListener('input', function () {
          syncContentMetaFromInputs('description');
          renderPreview();
          renderThumbnailPreview();
        });
      }
      if (thumbnailUrlInput instanceof HTMLInputElement) {
        thumbnailUrlInput.addEventListener('input', function () {
          syncContentMetaFromInputs('thumbnail');
          renderPreview();
          renderThumbnailPreview();
        });
      }
      if (postTagsInput instanceof HTMLInputElement) {
        postTagsInput.addEventListener('input', function () {
          syncContentMetaFromInputs('tags');
          renderTagBadges();
          renderThumbnailPreview();
        });
      }
      if (contentInput instanceof HTMLTextAreaElement) {
        contentInput.addEventListener('input', function () {
          renderPreview();
          syncMetaInputsFromContent();
          renderThumbnailPreview();
        });
      }

      if (!authApiBase) {
        submitButton.disabled = true;
        if (loginButton instanceof HTMLAnchorElement) {
          loginButton.hidden = true;
        }
        setStatus(statusEl, 'Quick PR flow requires PUBLIC_GITHUB_AUTH_WORKER_URL to be configured.', 'error');
        return;
      }

      try {
        var authResponse = await fetch(toAuthUrl('/me'), {
          credentials: 'include'
        });

        if (authResponse.ok) {
          var currentUser = await authResponse.json();
          submitButton.disabled = false;
          if (loginButton instanceof HTMLAnchorElement) {
            loginButton.hidden = true;
          }
          if (currentUser && typeof currentUser.login === 'string') {
            currentUsername = currentUser.login;
            setStatus(statusEl, 'Signed in as @' + currentUsername + '.', 'info');
          }
        } else {
          submitButton.disabled = true;
          if (loginButton instanceof HTMLAnchorElement) {
            loginButton.hidden = false;
          }
          setStatus(statusEl, 'Sign in first, then create your pull request from this form.', 'info');
        }
      } catch (_) {
        submitButton.disabled = true;
        if (loginButton instanceof HTMLAnchorElement) {
          loginButton.hidden = false;
        }
        setStatus(statusEl, 'Authentication check failed. Sign in again and retry.', 'error');
      }

      form.addEventListener('submit', async function (event) {
        event.preventDefault();
        if (submitButton.disabled) return;

        var filePath = refreshTargetPath();
        if (!filePath) {
          setStatus(statusEl, 'Category and post slug are required.', 'error');
          return;
        }

        var prBodyInput = form.elements.namedItem('prBody');
        var prTitle = prTitleInput instanceof HTMLInputElement ? prTitleInput.value.trim() : '';
        var prBody = prBodyInput instanceof HTMLTextAreaElement ? prBodyInput.value.trim() : '';
        var content = contentInput instanceof HTMLTextAreaElement ? contentInput.value : '';

        if (!prTitle) {
          setStatus(statusEl, 'PR title is required.', 'error');
          return;
        }

        if (!content.trim()) {
          setStatus(statusEl, 'Markdown content cannot be empty.', 'error');
          return;
        }

        submitButton.disabled = true;
        submitButton.setAttribute('aria-busy', 'true');
        setStatus(statusEl, 'Creating branch, committing markdown, and opening PR...', 'info');
        if (prLink instanceof HTMLAnchorElement) {
          prLink.hidden = true;
          prLink.href = '#';
        }

        try {
          var payload = {
            filePath: filePath,
            content: content,
            prTitle: prTitle,
            prBody: prBody
          };

          var response = await fetch(toAuthUrl('/contribute'), {
            method: 'POST',
            credentials: 'include',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
          });

          var data = null;
          try {
            data = await response.json();
          } catch (_) {
            data = null;
          }

          if (!response.ok) {
            var errorMessage = data && typeof data.error === 'string'
              ? data.error
              : 'Unable to create pull request. Try again.';
            throw new Error(errorMessage);
          }

          var prUrl = data && data.pullRequest && typeof data.pullRequest.url === 'string'
            ? data.pullRequest.url
            : '';

          if (prUrl) {
            if (prLink instanceof HTMLAnchorElement) {
              prLink.href = prUrl;
              prLink.hidden = false;
            }

            var opened = false;
            try {
              var popup = window.open(prUrl, '_blank', 'noopener,noreferrer');
              opened = Boolean(popup);
            } catch (_) {
              opened = false;
            }

            setStatus(
              statusEl,
              opened
                ? 'Pull request opened in a new tab.'
                : 'Pull request created successfully. Use the link to open it.',
              'success'
            );
          } else {
            setStatus(statusEl, 'Pull request created successfully.', 'success');
          }
        } catch (error) {
          var message = error instanceof Error ? error.message : 'Unable to create pull request.';
          setStatus(statusEl, message, 'error');
        } finally {
          submitButton.disabled = false;
          submitButton.removeAttribute('aria-busy');
        }
      });
    };

    var forms = Array.from(document.querySelectorAll('[data-quick-contribute]'));
    forms.forEach(function (entry) {
      if (entry instanceof HTMLElement) {
        void initializeForm(entry);
      }
    });
  })();
</script>
