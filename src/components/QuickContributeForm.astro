        if (prLink instanceof HTMLAnchorElement) {
          prLink.hidden = true;
          prLink.href = '#';
        }

        try {
          var payload = {
            filePath: filePath,
            content: content,
            prTitle: prTitle,
            prBody: prBody
          };

          var response = await fetch(toAuthUrl('/contribute'), {
            method: 'POST',
            credentials: 'include',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
          });

          var data = null;
          try {
            data = await response.json();
          } catch (_) {
            data = null;
          }

          if (!response.ok) {
            var errorMessage = data && typeof data.error === 'string'
              ? data.error
              : 'Unable to create Pull Request. Try again.';
            throw new Error(errorMessage);
          }

          var prUrl = data && data.pullRequest && typeof data.pullRequest.url === 'string'
            ? data.pullRequest.url
            : '';

          if (prUrl) {
            if (prLink instanceof HTMLAnchorElement) {
              prLink.href = prUrl;
              prLink.hidden = false;
            }

            var opened = false;
            try {
              var popup = window.open(prUrl, '_blank', 'noopener,noreferrer');
              opened = Boolean(popup);
            } catch (_) {
              opened = false;
            }

            setStatus(
              statusEl,
              opened
                ? 'Pull request opened in a new tab.'
                : 'Pull request created successfully. Use the link to open it.',
              'success'
            );
          } else {
            setStatus(statusEl, 'Pull request created successfully.', 'success');
          }
        } catch (error) {
          var message = error instanceof Error ? error.message : 'Unable to create Pull Request.';
          setStatus(statusEl, message, 'error');
        } finally {
          submitButton.disabled = false;
          submitButton.removeAttribute('aria-busy');
        }
      });
    };

    var forms = Array.from(document.querySelectorAll('[data-quick-contribute]'));
    forms.forEach(function (entry) {
      if (entry instanceof HTMLElement) {
        void initializeForm(entry);
      }
    });
  })();
</script>
