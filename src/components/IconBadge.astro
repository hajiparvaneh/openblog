---
type Props = {
  label: string;
  icon: string;
  class?: string;
};

const { label, icon, class: className = '' } = Astro.props as Props;
const rootClass = `post-chip-label icon-label ${className}`.trim();
---

<span class={rootClass}>
  <i class={`ti ti-${icon} post-chip-icon`} aria-hidden="true"></i>
  <span>{label}</span>
</span>
