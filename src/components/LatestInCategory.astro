---
import PostCard from './PostCard.astro';
import { getLatestContributorByPost, getPosts } from '../lib/openblog';

type Props = {
  category: string;
  currentPostSlug: string;
  limit?: number;
  title?: string;
  emptyMessage?: string;
};

const {
  category,
  currentPostSlug,
  limit = 6,
  title,
  emptyMessage = 'No other posts in this category yet.'
} = Astro.props as Props;
const sectionTitle = title ?? 'Related posts';

const allPosts = getPosts();
const latestContributorByPost = getLatestContributorByPost();
const latestInCategory = allPosts
  .filter((categoryPost) => categoryPost.category === category && categoryPost.slug !== currentPostSlug)
  .map((categoryPost) => {
    const latestContributionAt = latestContributorByPost.get(categoryPost.slug)?.lastContributionAt;
    const lastUpdatedAt = latestContributionAt ?? (categoryPost.date ? `${categoryPost.date}T00:00:00Z` : '');
    return {
      post: categoryPost,
      lastUpdatedAt
    };
  })
  .sort(
    (a, b) =>
      b.lastUpdatedAt.localeCompare(a.lastUpdatedAt) ||
      b.post.date.localeCompare(a.post.date) ||
      a.post.slug.localeCompare(b.post.slug)
  )
  .slice(0, limit);
---

<section class="card category-latest-posts">
  <p class="kicker icon-label"><i class="ti ti-clock-hour-4 icon-sm" aria-hidden="true"></i>{sectionTitle}</p>
  {latestInCategory.length === 0 ? (
    <p class="meta">{emptyMessage}</p>
  ) : (
    <div class="post-grid">
      {latestInCategory.map((categoryPostRecord) => (
        <PostCard
          post={categoryPostRecord.post}
          showCategory={false}
          displayDate={categoryPostRecord.lastUpdatedAt}
          dateSortValue={categoryPostRecord.lastUpdatedAt}
        />
      ))}
    </div>
  )}
</section>
