---
import '../styles/global.css';
import { getPosts } from '../lib/game';
const { title = 'OpenBlog' } = Astro.props;
const categories = [...new Set(getPosts().map((post) => post.category))].sort((a, b) => a.localeCompare(b));
const categoryPath = (category: string) => `/categories/${encodeURIComponent(category)}`;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="OpenBlog is a Git-based collaborative blog game where accepted pull requests earn points." />
  </head>
  <body>
    <div class="container">
      <nav class="nav">
        <a href="/">Home</a>
        <a href="/leaderboard">Leaderboard</a>
        <a href="/how-to-contribute">How to contribute</a>
      </nav>
      {categories.length > 0 && (
        <nav class="category-nav card" aria-label="Post categories">
          <span class="meta">Categories</span>
          <div class="category-links">
            {categories.map((category) => (
              <a class="category-link" href={categoryPath(category)}>{category}</a>
            ))}
          </div>
        </nav>
      )}
      <slot />
    </div>
  </body>
</html>
