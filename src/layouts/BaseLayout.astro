---
import '../styles/global.css';
import CookieConsentHead from '../components/CookieConsentHead.astro';
import CookieConsentManager from '../components/CookieConsentManager.astro';
import UserAvatar from '../components/UserAvatar.astro';
import { getCategoryPath, getLatestContributors, getPosts, getProfilePath } from '../lib/openblog';
import { toAbsoluteUrl } from '../lib/seo';
import { getSiteUrl } from '../lib/site';
type JsonLd = Record<string, unknown>;

type BaseLayoutProps = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  pageLang?: string;
  ogType?: 'website' | 'article' | 'profile';
  ogImagePath?: string;
  ogImageAlt?: string;
  robots?: string;
  publishedTime?: string;
  modifiedTime?: string;
  structuredData?: JsonLd | JsonLd[];
};

const {
  title = 'OpenBlog',
  description = 'OpenBlog is a Git-based collaborative blog where accepted pull requests create public proof of work and help contributors grow visibility.',
  canonicalPath = Astro.url.pathname,
  pageLang = 'en',
  ogType = 'website',
  ogImagePath = '/og-default.png',
  ogImageAlt = 'OpenBlog',
  robots = 'index, follow',
  publishedTime,
  modifiedTime,
  structuredData
} = Astro.props as BaseLayoutProps;

const siteUrl = getSiteUrl(Astro.site);
const canonicalUrl = toAbsoluteUrl(canonicalPath, siteUrl);
const ogImageUrl = toAbsoluteUrl(ogImagePath, siteUrl);
const faviconIcoHref = '/favicon.ico';
const favicon16Href = '/favicon-16x16.png';
const favicon32Href = '/favicon-32x32.png';
const appleTouchIconHref = '/apple-touch-icon.png';
const manifestHref = '/site.webmanifest';
const logoDarkSrc = '/openblog-logo-dark.png';
const logoLightSrc = '/openblog-logo-light.png';
const jsonLdEntries = Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : [];
const serializedStructuredData = jsonLdEntries.map((entry) => JSON.stringify(entry).replace(/</g, '\\u003c'));
const posts = getPosts();
const categories = [...posts.reduce((map, post) => {
  const current = map.get(post.category);
  if (current) {
    current.postCount += 1;
  } else {
    map.set(post.category, { label: post.categoryLabel, postCount: 1 });
  }
  return map;
}, new Map<string, { label: string; postCount: number }>()).entries()]
  .sort((a, b) => b[1].postCount - a[1].postCount || a[1].label.localeCompare(b[1].label));
const latestContributors = getLatestContributors(10);
const repoUrl = 'https://github.com/hajiparvaneh/openblog';
const hasSidebarExtra = Astro.slots.has('sidebar-extra');
const configuredAuthWorkerUrl = (import.meta.env.PUBLIC_GITHUB_AUTH_WORKER_URL ?? '').trim();
const authWorkerBaseUrl = (() => {
  if (!configuredAuthWorkerUrl) return '';
  try {
    const parsed = new URL(configuredAuthWorkerUrl);
    const normalizedPath = parsed.pathname.replace(/\/+$/, '');
    return `${parsed.origin}${normalizedPath}`;
  } catch {
    return '';
  }
})();
---
<html lang={pageLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#f6f8fa" />
    <meta name="application-name" content="OpenBlog" />
    <meta name="apple-mobile-web-app-title" content="OpenBlog" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="msapplication-TileColor" content="#f6f8fa" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={faviconIcoHref} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={favicon32Href} />
    <link rel="icon" type="image/png" sizes="16x16" href={favicon16Href} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIconHref} />
    <link rel="manifest" href={manifestHref} />
    <link rel="shortcut icon" href={faviconIcoHref} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="OpenBlog" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    {ogType === 'article' && publishedTime ? <meta property="article:published_time" content={publishedTime} /> : null}
    {ogType === 'article' && modifiedTime ? <meta property="article:modified_time" content={modifiedTime} /> : null}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    {serializedStructuredData.map((item) => (
      <script type="application/ld+json" set:html={item} />
    ))}

    <CookieConsentHead />

    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="dns-prefetch" href="//cdn.jsdelivr.net" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />
    <script is:inline>
      (function () {
        var storageKey = 'openblog-theme';
        var saved = null;
        try {
          saved = localStorage.getItem(storageKey);
        } catch (_) {}
        var theme = saved === 'light' || saved === 'dark' ? saved : 'light';
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header card">
        <a class="brand" href="/">
          <span class="brand-main">
            <span class="brand-icon-wrap" aria-hidden="true">
              <img class="brand-icon brand-icon-dark" src={logoDarkSrc} alt="" loading="eager" decoding="async" width="44" height="44" />
              <img class="brand-icon brand-icon-light" src={logoLightSrc} alt="" loading="eager" decoding="async" width="44" height="44" />
            </span>
          </span>
          <span class="brand-copy">
            <span class="brand-mark">Open<span class="brand-mark-primary">Blog</span></span>
            <span class="brand-tagline">Collaborative writing for portfolio and reputation growth</span>
          </span>
        </a>
        <div class="site-header-actions" id="site-header-actions" data-menu-open="false">
          <button
            class="header-menu-toggle"
            id="header-menu-toggle"
            type="button"
            aria-label="Toggle navigation menu"
            aria-controls="main-nav"
            aria-expanded="false"
          >
            <span class="icon-label">
              <i class="ti ti-menu-2 menu-icon menu-icon-open icon-sm" aria-hidden="true"></i>
              <i class="ti ti-x menu-icon menu-icon-close icon-sm" aria-hidden="true"></i>
            </span>
          </button>
          <nav class="nav" id="main-nav" aria-label="Main navigation">
            <a href="/"><i class="ti ti-home icon-sm" aria-hidden="true"></i>Home</a>
            <a href="/leaderboard"><i class="ti ti-trophy icon-sm" aria-hidden="true"></i>Leaderboard</a>
            <a href="/how-to-contribute"><i class="ti ti-pencil icon-sm" aria-hidden="true"></i>Contribute</a>
          </nav>
          <div class="header-auth" id="header-auth" data-open="false" data-state="guest">
            <a class="header-auth-login" id="header-auth-login" href="/login">
              <i class="ti ti-brand-github icon-sm" aria-hidden="true"></i>
              <span class="header-auth-label">Sign in</span>
            </a>
            <div class="header-auth-user" id="header-auth-user" hidden>
              <button
                class="header-auth-trigger"
                id="header-auth-trigger"
                type="button"
                aria-label="Open account menu"
                aria-expanded="false"
                aria-controls="header-auth-menu"
              >
                <img id="header-auth-avatar" class="header-auth-avatar" src="" alt="" loading="lazy" decoding="async" width="24" height="24" />
                <span id="header-auth-name" class="header-auth-name">@github</span>
                <i class="ti ti-chevron-down icon-sm" aria-hidden="true"></i>
              </button>
              <div class="header-auth-menu" id="header-auth-menu" role="menu" hidden>
                <a id="header-auth-openblog-profile" href="/profile/@github" role="menuitem">
                  <i class="ti ti-user icon-sm" aria-hidden="true"></i>
                  OpenBlog profile
                </a>
                <a id="header-auth-profile" href="https://github.com" target="_blank" rel="noopener noreferrer" role="menuitem">
                  <i class="ti ti-external-link icon-sm" aria-hidden="true"></i>
                  GitHub profile
                </a>
                <button id="header-auth-logout" type="button" role="menuitem">
                  <i class="ti ti-logout icon-sm" aria-hidden="true"></i>
                  Sign out
                </button>
              </div>
            </div>
          </div>
          <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
            <span class="icon-label">
              <i class="ti ti-sun theme-icon theme-icon-sun icon-sm" aria-hidden="true"></i>
              <i class="ti ti-moon theme-icon theme-icon-moon icon-sm" aria-hidden="true"></i>
              <span id="theme-toggle-label">Theme: Light</span>
            </span>
          </button>
        </div>
      </header>

      {categories.length > 0 ? (
        <div class="content-layout">
          <main class="container">
            <slot />
          </main>

          <aside class="category-sidebar card">
            <section class="sidebar-block">
              <p class="kicker icon-label"><i class="ti ti-pencil-plus icon-sm" aria-hidden="true"></i>New Post</p>
              <p class="meta">Want to contribute? Clone the repo, add a new <code>.md</code> file, open a PR, and grow your public GitHub proof of work.</p>
              <a class="sidebar-link" href={repoUrl} target="_blank" rel="noopener noreferrer">
                <i class="ti ti-brand-github icon-sm" aria-hidden="true"></i>
                Open GitHub repo
              </a>
              <a class="sidebar-sub-link" href="/how-to-contribute">How to contribute</a>
            </section>

            <hr class="sidebar-sep" />
            <p class="kicker icon-label"><i class="ti ti-category icon-sm" aria-hidden="true"></i>Categories</p>
            <nav aria-label="Post categories">
              <div class="category-links category-links-sidebar">
                {categories.map(([category, categoryMeta]) => (
                  <a class="category-link" href={getCategoryPath(category)}>
                    <span>{categoryMeta.label}</span>
                    <span class="badge">{categoryMeta.postCount}</span>
                  </a>
                ))}
              </div>
            </nav>

            {hasSidebarExtra && (
              <>
                <hr class="sidebar-sep" />
                <slot name="sidebar-extra" />
              </>
            )}

            {latestContributors.length > 0 && (
              <>
                <hr class="sidebar-sep" />
                <p class="kicker icon-label"><i class="ti ti-users icon-sm" aria-hidden="true"></i>Latest contributors</p>
                <ul class="sidebar-contributors" aria-label="Latest contributors">
                  {latestContributors.map((contributor) => (
                    <li>
                      <a
                        class="sidebar-contributor-link"
                        href={getProfilePath(contributor.username)}
                        aria-label={`@${contributor.username}`}
                        title={`@${contributor.username}`}
                      >
                        <UserAvatar
                          username={contributor.username}
                          avatarUrl={contributor.avatarUrl}
                          size={64}
                          class="sidebar-avatar"
                          alt=""
                          width={28}
                          height={28}
                        />
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            )}

            <hr class="sidebar-sep" />
            <section class="sidebar-block">
              <p class="kicker icon-label"><i class="ti ti-alert-circle icon-sm" aria-hidden="true"></i>Seeing an issue?</p>
              <p class="meta">Found a bug or typo? Let us know by opening an issue.</p>
              <a
                class="sidebar-link"
                href="https://github.com/hajiparvaneh/openblog/issues/new"
                target="_blank"
                rel="noopener noreferrer"
              >
                <i class="ti ti-bug icon-sm" aria-hidden="true"></i>
                Open an issue
              </a>
            </section>
          </aside>
        </div>
      ) : (
        <main class="container">
          <slot />
        </main>
      )}

      <footer class="site-footer meta">
        <span class="icon-label">
          <i class="ti ti-edit icon-sm" aria-hidden="true"></i>
          Built by contributors in public. Improve a post, open a PR, and strengthen your portfolio visibility.
        </span>
        <button class="cookie-settings-button" id="cookie-settings-button" type="button">
          Cookie settings
        </button>
      </footer>
    </div>
    <script is:inline type="text/javascript">
      var _Hasync = _Hasync || [];
      _Hasync.push(['Histats.start', '1,5015609,4,0,0,0,00010000']);
      _Hasync.push(['Histats.fasi', '1']);
      _Hasync.push(['Histats.track_hits', '']);
      (function () {
        var hs = document.createElement('script');
        hs.type = 'text/javascript';
        hs.async = true;
        hs.src = '//s10.histats.com/js15_as.js';
        (document.getElementsByTagName('head')[0] || document.getElementsByTagName('body')[0]).appendChild(hs);
      })();
    </script>
    <noscript>
      <a href="/" target="_blank">
        <img src="//sstatic1.histats.com/0.gif?5015609&amp;101" alt="website hit counter" />
      </a>
    </noscript>
    <CookieConsentManager />
    <script is:inline define:vars={{ authWorkerBaseUrl }}>
      (function () {
        var storageKey = 'openblog-theme';
        var authApiBase = typeof authWorkerBaseUrl === 'string' ? authWorkerBaseUrl : '';
        var button = document.getElementById('theme-toggle');
        var label = document.getElementById('theme-toggle-label');
        var themeColor = document.querySelector('meta[name="theme-color"]');
        var headerActions = document.getElementById('site-header-actions');
        var menuButton = document.getElementById('header-menu-toggle');
        var mainNav = document.getElementById('main-nav');
        var authRoot = document.getElementById('header-auth');
        var authLoginLink = document.getElementById('header-auth-login');
        var authUserWrap = document.getElementById('header-auth-user');
        var authTrigger = document.getElementById('header-auth-trigger');
        var authMenu = document.getElementById('header-auth-menu');
        var authAvatar = document.getElementById('header-auth-avatar');
        var authName = document.getElementById('header-auth-name');
        var authOpenblogProfileLink = document.getElementById('header-auth-openblog-profile');
        var authProfileLink = document.getElementById('header-auth-profile');
        var authLogoutButton = document.getElementById('header-auth-logout');

        var toAuthUrl = function (path) {
          return authApiBase ? authApiBase + path : path;
        };

        var getLoginUrl = function () {
          var url = new URL(toAuthUrl('/login'), window.location.origin);
          url.searchParams.set('return_to', window.location.href);
          return url.toString();
        };

        var getOpenblogProfilePath = function (username) {
          if (typeof username !== 'string') return '/profile/@github';
          var handle = username.trim().replace(/^@+/, '');
          return handle ? '/profile/@' + encodeURIComponent(handle) : '/profile/@github';
        };

        var setAuthMenuOpen = function (open) {
          if (!authRoot || !authTrigger || !authMenu) return;
          var isOpen = Boolean(open);
          authRoot.setAttribute('data-open', String(isOpen));
          authTrigger.setAttribute('aria-expanded', String(isOpen));
          authMenu.hidden = !isOpen;
        };

        var renderGuest = function () {
          if (authRoot) authRoot.setAttribute('data-state', 'guest');
          if (authUserWrap) authUserWrap.hidden = true;
          if (authLoginLink) {
            authLoginLink.hidden = false;
            authLoginLink.setAttribute('href', getLoginUrl());
          }
          if (authAvatar) {
            authAvatar.src = '';
            authAvatar.alt = '';
          }
          if (authName) {
            authName.textContent = '@github';
          }
          if (authOpenblogProfileLink) {
            authOpenblogProfileLink.setAttribute('href', '/profile/@github');
          }
          if (authProfileLink) {
            authProfileLink.setAttribute('href', 'https://github.com');
          }
          setAuthMenuOpen(false);
        };

        var renderUser = function (user) {
          if (!user || typeof user !== 'object') {
            renderGuest();
            return;
          }

          if (authRoot) authRoot.setAttribute('data-state', 'authenticated');
          if (authLoginLink) authLoginLink.hidden = true;
          if (authUserWrap) authUserWrap.hidden = false;
          if (authAvatar && typeof user.avatar_url === 'string') {
            authAvatar.src = user.avatar_url;
          }
          if (authAvatar && typeof user.login === 'string') {
            authAvatar.alt = user.login + ' avatar';
          }
          if (authName && typeof user.login === 'string') {
            authName.textContent = '@' + user.login;
          }
          if (authOpenblogProfileLink && typeof user.login === 'string') {
            authOpenblogProfileLink.setAttribute('href', getOpenblogProfilePath(user.login));
          }
          if (authProfileLink && typeof user.html_url === 'string') {
            authProfileLink.setAttribute('href', user.html_url);
          }
        };

        var loadAuthUser = async function () {
          try {
            var response = await fetch(toAuthUrl('/me'), { credentials: 'include' });
            if (response.status === 401) {
              renderGuest();
              return;
            }
            if (!response.ok) {
              throw new Error('Unexpected status: ' + response.status);
            }
            var user = await response.json();
            renderUser(user);
          } catch (_) {
            renderGuest();
          }
        };

        if (authTrigger) {
          authTrigger.addEventListener('click', function () {
            var isOpen = authTrigger.getAttribute('aria-expanded') === 'true';
            setAuthMenuOpen(!isOpen);
          });
        }

        if (authLogoutButton) {
          authLogoutButton.addEventListener('click', async function () {
            authLogoutButton.setAttribute('disabled', 'true');
            try {
              await fetch(toAuthUrl('/logout'), {
                method: 'POST',
                credentials: 'include'
              });
            } catch (_) {
            } finally {
              authLogoutButton.removeAttribute('disabled');
              renderGuest();
            }
          });
        }

        void loadAuthUser();

        var applyTheme = function (theme) {
          document.documentElement.setAttribute('data-theme', theme);
          document.documentElement.style.colorScheme = theme;
          if (themeColor) {
            themeColor.setAttribute('content', theme === 'dark' ? '#0d1117' : '#f6f8fa');
          }
          if (label) {
            label.textContent = theme === 'dark' ? 'Theme: Dark' : 'Theme: Light';
          }
          if (button) {
            button.setAttribute('aria-pressed', String(theme === 'dark'));
          }
        };

        var current = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
        applyTheme(current);

        if (button) {
          button.addEventListener('click', function () {
            current = current === 'dark' ? 'light' : 'dark';
            applyTheme(current);
            try {
              localStorage.setItem(storageKey, current);
            } catch (_) {}
          });
        }

        if (!headerActions || !menuButton || !mainNav) return;

        var mobileMenu = window.matchMedia('(max-width: 860px)');

        var setMenuOpen = function (isOpen) {
          var open = Boolean(isOpen);
          headerActions.setAttribute('data-menu-open', String(open));
          menuButton.setAttribute('aria-expanded', String(open));
        };

        setMenuOpen(false);

        menuButton.addEventListener('click', function () {
          var isOpen = menuButton.getAttribute('aria-expanded') === 'true';
          setMenuOpen(!isOpen);
        });

        mainNav.addEventListener('click', function (event) {
          if (!mobileMenu.matches) return;
          if (!(event.target instanceof Element)) return;
          if (!event.target.closest('a')) return;
          setMenuOpen(false);
        });

        document.addEventListener('click', function (event) {
          if (!(event.target instanceof Node)) return;
          if (authRoot && !authRoot.contains(event.target)) {
            setAuthMenuOpen(false);
          }
          if (!mobileMenu.matches) return;
          if (headerActions.contains(event.target)) return;
          setMenuOpen(false);
        });

        document.addEventListener('keydown', function (event) {
          if (event.key !== 'Escape') return;
          setAuthMenuOpen(false);
          setMenuOpen(false);
        });

        mobileMenu.addEventListener('change', function () {
          setMenuOpen(false);
        });
      })();
    </script>
  </body>
</html>
