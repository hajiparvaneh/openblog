---
import '../styles/global.css';
import { getCategoryPath, getLatestContributors, getPosts } from '../lib/openblog';
const { title = 'OpenBlog' } = Astro.props;
const categories = [...new Map(getPosts().map((post) => [post.category, post.categoryLabel])).entries()]
  .sort((a, b) => a[1].localeCompare(b[1]));
const latestContributors = getLatestContributors(10);
const repoUrl = 'https://github.com/hajiparvaneh/openblog';
const hasSidebarExtra = Astro.slots.has('sidebar-extra');
const getAvatarUrl = (username: string, avatarUrl?: string | null) =>
  avatarUrl ?? `https://github.com/${username}.png?size=64`;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="OpenBlog is a Git-based collaborative blog where accepted pull requests earn points." />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />
    <script is:inline>
      (function () {
        var storageKey = 'openblog-theme';
        var saved = null;
        try {
          saved = localStorage.getItem(storageKey);
        } catch (_) {}
        var theme = saved === 'light' || saved === 'dark' ? saved : 'dark';
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header card">
        <a class="brand" href="/">
          <span class="brand-mark">OpenBlog</span>
          <span class="brand-tagline">Community writing, tracked by merged PRs</span>
        </a>
        <div class="site-header-actions">
          <nav class="nav" aria-label="Main navigation">
            <a href="/"><i class="ti ti-home icon-sm" aria-hidden="true"></i>Home</a>
            <a href="/leaderboard"><i class="ti ti-trophy icon-sm" aria-hidden="true"></i>Leaderboard</a>
            <a href="/how-to-contribute"><i class="ti ti-pencil icon-sm" aria-hidden="true"></i>Contribute</a>
          </nav>
          <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
            <span class="icon-label">
              <i class="ti ti-sun theme-icon theme-icon-sun icon-sm" aria-hidden="true"></i>
              <i class="ti ti-moon theme-icon theme-icon-moon icon-sm" aria-hidden="true"></i>
              <span id="theme-toggle-label">Theme: Dark</span>
            </span>
          </button>
        </div>
      </header>

      {categories.length > 0 ? (
        <div class="content-layout">
          <main class="container">
            <slot />
          </main>

          <aside class="category-sidebar card">
            <section class="sidebar-block">
              <p class="kicker icon-label"><i class="ti ti-pencil-plus icon-sm" aria-hidden="true"></i>New Post</p>
              <p class="meta">Want to contribute? Clone the repo, add a new <code>.md</code> file, and open a PR.</p>
              <a class="sidebar-link" href={repoUrl} target="_blank" rel="noopener noreferrer">
                <i class="ti ti-brand-github icon-sm" aria-hidden="true"></i>
                Open GitHub repo
              </a>
              <a class="sidebar-sub-link" href="/how-to-contribute">How to contribute</a>
            </section>

            <hr class="sidebar-sep" />

            {hasSidebarExtra && (
              <>
                <slot name="sidebar-extra" />
                <hr class="sidebar-sep" />
              </>
            )}

            <p class="kicker icon-label"><i class="ti ti-category icon-sm" aria-hidden="true"></i>Categories</p>
            <nav aria-label="Post categories">
              <div class="category-links category-links-sidebar">
                {categories.map(([category, categoryLabel]) => (
                  <a class="category-link" href={getCategoryPath(category)}>{categoryLabel}</a>
                ))}
              </div>
            </nav>

            {latestContributors.length > 0 && (
              <>
                <hr class="sidebar-sep" />
                <p class="kicker icon-label"><i class="ti ti-users icon-sm" aria-hidden="true"></i>Latest contributors</p>
                <ul class="sidebar-contributors" aria-label="Latest contributors">
                  {latestContributors.map((contributor) => (
                    <li>
                      <a
                        class="sidebar-contributor-link"
                        href={contributor.profileUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={`@${contributor.username}`}
                        title={`@${contributor.username}`}
                      >
                        <img
                          class="avatar sidebar-avatar"
                          src={getAvatarUrl(contributor.username, contributor.avatarUrl)}
                          alt=""
                          loading="lazy"
                          decoding="async"
                          width="28"
                          height="28"
                        />
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            )}
          </aside>
        </div>
      ) : (
        <main class="container">
          <slot />
        </main>
      )}

      <footer class="site-footer meta">
        <span class="icon-label">
          <i class="ti ti-edit icon-sm" aria-hidden="true"></i>
          Built by contributors in public. Improve a post, open a PR, and earn points.
        </span>
      </footer>
    </div>
    <script is:inline>
      (function () {
        var storageKey = 'openblog-theme';
        var button = document.getElementById('theme-toggle');
        var label = document.getElementById('theme-toggle-label');
        if (!button) return;

        var applyTheme = function (theme) {
          document.documentElement.setAttribute('data-theme', theme);
          document.documentElement.style.colorScheme = theme;
          if (label) {
            label.textContent = theme === 'dark' ? 'Theme: Dark' : 'Theme: Light';
          }
          button.setAttribute('aria-pressed', String(theme === 'dark'));
        };

        var current = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
        applyTheme(current);

        button.addEventListener('click', function () {
          current = current === 'dark' ? 'light' : 'dark';
          applyTheme(current);
          try {
            localStorage.setItem(storageKey, current);
          } catch (_) {}
        });
      })();
    </script>
  </body>
</html>
