---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeaturedPostsSlider from '../../components/FeaturedPostsSlider.astro';
import PostCard from '../../components/PostCard.astro';
import UserAvatar from '../../components/UserAvatar.astro';
import { getCategoryLeaderboardByWindowWithFallback, getCategoryPath, getPosts, getProfilePath, normalizeCategoryKey } from '../../lib/openblog';
import { toAbsoluteUrl } from '../../lib/seo';
import { getSiteUrl } from '../../lib/site';

export function getStaticPaths() {
  const categoryMap = new Map<string, string>();
  for (const post of getPosts()) {
    if (!categoryMap.has(post.category)) {
      categoryMap.set(post.category, post.categoryLabel);
    }
  }

  return [...categoryMap.entries()].map(([category, categoryLabel]) => ({
    params: { category: encodeURIComponent(category) },
    props: { categoryLabel }
  }));
}

const categoryParam = Astro.params.category ?? '';
const category = normalizeCategoryKey(decodeURIComponent(categoryParam));
const posts = getPosts().filter((post) => post.category === category);
const categoryLeaderboardResult = getCategoryLeaderboardByWindowWithFallback(category, 'month');
const categoryLeaderboard = categoryLeaderboardResult.entries;
const categoryLeaderboardUsesFallback = categoryLeaderboardResult.resolvedWindow === 'all';
const postsPerPage = 6;
const postsTotalPages = Math.max(1, Math.ceil(posts.length / postsPerPage));
const currentPage = 1;
const pageStart = (currentPage - 1) * postsPerPage;
const paginatedPosts = posts.slice(pageStart, pageStart + postsPerPage);
const postPageNumbers = Array.from({ length: postsTotalPages }, (_, index) => index + 1);
const categoryLabel = posts[0]?.categoryLabel ?? Astro.props.categoryLabel ?? category;
const categoryLeaderboardTitle = categoryLeaderboardUsesFallback
  ? `${categoryLabel} leaderboard (all time)`
  : `${categoryLabel} monthly leaderboard`;
const categoryLeaderboardEmptyState = categoryLeaderboardUsesFallback
  ? 'No scored contributions for this category yet.'
  : 'No scored contributions for this category this month.';
const categoryBasePath = getCategoryPath(category);
const getCategoryPagePath = (page: number): string => (page <= 1 ? categoryBasePath : `${categoryBasePath}/page/${page}`);
const canonicalPath = categoryBasePath;
const pageDescription = `Browse ${posts.length} ${categoryLabel} post${posts.length === 1 ? '' : 's'} on OpenBlog and see the top ${categoryLeaderboardUsesFallback ? 'contributors' : 'monthly contributors'} for this category.`;
const siteUrl = getSiteUrl(Astro.site);
const canonicalUrl = toAbsoluteUrl(canonicalPath, siteUrl);
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${categoryLabel} posts`,
    description: pageDescription,
    url: canonicalUrl
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: toAbsoluteUrl('/', siteUrl)
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: categoryLabel,
        item: canonicalUrl
      }
    ]
  }
];

if (posts.length === 0) {
  throw new Error(`Category not found: ${category}`);
}
---
<BaseLayout
  title={`${categoryLabel} | Categories | OpenBlog`}
  description={pageDescription}
  canonicalPath={canonicalPath}
  structuredData={structuredData}
>
  <section class="card">
    <p class="kicker icon-label"><i class="ti ti-category icon-sm" aria-hidden="true"></i>Category</p>
    <h1>{categoryLabel}</h1>
    <p class="meta icon-label">
      <i class="ti ti-notes icon-sm" aria-hidden="true"></i>
      {posts.length} post{posts.length > 1 ? 's' : ''} available in this topic.
    </p>
  </section>

  <FeaturedPostsSlider
    posts={posts}
    category={category}
    title={`${categoryLabel} featured posts`}
    class="card"
  />

  <section class="list paginated-list">
    <p id="category-posts-page-info" class="meta pagination-info">Page {currentPage} of {postsTotalPages} ({posts.length} posts)</p>
    <div class="post-grid">
      {paginatedPosts.map((post) => (
        <PostCard
          post={post}
          showCategory={false}
        />
      ))}
    </div>

    {postsTotalPages > 1 && (
      <nav class="leaderboard-pagination" aria-label={`${categoryLabel} posts pages`}>
        <a
          id="category-posts-prev"
          class:list={['page-control', currentPage <= 1 && 'is-disabled']}
          href={getCategoryPagePath(Math.max(1, currentPage - 1))}
          aria-disabled={currentPage <= 1 ? 'true' : undefined}
        >
          Previous
        </a>
        <ul class="page-links" aria-label="Page numbers">
          {postPageNumbers.map((page) => (
            <li>
              <a class:list={['page-link', page === currentPage && 'is-active']} href={getCategoryPagePath(page)} aria-current={page === currentPage ? 'page' : undefined}>{page}</a>
            </li>
          ))}
        </ul>
        <a
          id="category-posts-next"
          class:list={['page-control', currentPage >= postsTotalPages && 'is-disabled']}
          href={getCategoryPagePath(Math.min(postsTotalPages, currentPage + 1))}
          aria-disabled={currentPage >= postsTotalPages ? 'true' : undefined}
        >
          Next
        </a>
      </nav>
    )}
  </section>

  <section class="card table-wrap">
    <h2 class="icon-label"><i class="ti ti-trophy icon-sm" aria-hidden="true"></i>{categoryLeaderboardTitle}</h2>
    {categoryLeaderboard.length === 0 ? (
      <p class="meta">{categoryLeaderboardEmptyState}</p>
    ) : (
      <table class="table">
        <thead>
          <tr>
            <th scope="col">Rank</th>
            <th scope="col">User</th>
            <th scope="col">Points</th>
            <th scope="col">PRs</th>
          </tr>
        </thead>
        <tbody>
          {categoryLeaderboard.map((user, index) => (
            <tr>
              <td>#{index + 1}</td>
              <td>
                <a class="user-chip user-link" href={getProfilePath(user.username)}>
                  <UserAvatar username={user.username} avatarUrl={user.avatarUrl} size={80} />
                  <span class="user-handle">@{user.username}</span>
                </a>
              </td>
              <td>
                <span class="points-inline">
                  <i class="ti ti-sparkles icon-sm points-icon" aria-hidden="true"></i>
                  {user.totalPoints}
                </span>
              </td>
              <td>{user.acceptedPrs}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </section>

  <script is:inline>
    (function () {
      var basePath = window.location.pathname;
      if (!basePath || basePath.indexOf('/categories/') !== 0) return;
      var params = new URLSearchParams(window.location.search);
      if (!params.has('page')) return;
      var requestedPage = Number(params.get('page') || '1');
      if (!Number.isFinite(requestedPage) || requestedPage < 1) return;
      var maxPage = Math.max(1, document.querySelectorAll('.page-link').length);
      var normalizedPage = Math.floor(requestedPage);
      if (normalizedPage > maxPage) normalizedPage = maxPage;
      if (normalizedPage <= 1) {
        window.location.replace(basePath + window.location.hash);
        return;
      }
      window.location.replace(basePath + '/page/' + normalizedPage + window.location.hash);
    })();
  </script>

  <style>
    .leaderboard-pagination {
      margin-top: 0.45rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }

    .page-links {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
    }

    .page-control,
    .page-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 2rem;
      min-height: 2rem;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--surface);
      color: var(--text);
      font-family: var(--font-main);
      font-size: 0.82rem;
      font-weight: 600;
      line-height: 1;
      padding: 0.35rem 0.55rem;
      text-decoration: none;
    }

    .page-link.is-active {
      border-color: var(--primary);
      background: var(--surface-soft);
      color: var(--primary);
      text-decoration: none;
    }

    .page-control.is-disabled {
      opacity: 0.55;
      pointer-events: none;
    }

    @media (max-width: 860px) {
      .leaderboard-pagination {
        justify-content: center;
      }
    }
  </style>
</BaseLayout>
