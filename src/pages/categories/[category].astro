---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import UserAvatar from '../../components/UserAvatar.astro';
import { getCategoryLeaderboard, getCategoryPath, getPosts, getProfilePath, normalizeCategoryKey } from '../../lib/openblog';
import { toAbsoluteUrl } from '../../lib/seo';
import { getSiteUrl } from '../../lib/site';

export function getStaticPaths() {
  const categoryMap = new Map<string, string>();
  for (const post of getPosts()) {
    if (!categoryMap.has(post.category)) {
      categoryMap.set(post.category, post.categoryLabel);
    }
  }

  return [...categoryMap.entries()].map(([category, categoryLabel]) => ({
    params: { category: encodeURIComponent(category) },
    props: { categoryLabel }
  }));
}

const categoryParam = Astro.params.category ?? '';
const category = normalizeCategoryKey(decodeURIComponent(categoryParam));
const posts = getPosts().filter((post) => post.category === category);
const categoryLeaderboard = getCategoryLeaderboard(category);
const postsPerPage = 6;
const postsTotalPages = Math.max(1, Math.ceil(posts.length / postsPerPage));
const postPageNumbers = Array.from({ length: postsTotalPages }, (_, index) => index + 1);
const categoryLabel = posts[0]?.categoryLabel ?? Astro.props.categoryLabel ?? category;
const canonicalPath = getCategoryPath(category);
const pageDescription = `Browse ${posts.length} ${categoryLabel} post${posts.length === 1 ? '' : 's'} on OpenBlog and see the top contributors for this category.`;
const siteUrl = getSiteUrl(Astro.site);
const canonicalUrl = toAbsoluteUrl(canonicalPath, siteUrl);
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${categoryLabel} posts`,
    description: pageDescription,
    url: canonicalUrl
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: toAbsoluteUrl('/', siteUrl)
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: categoryLabel,
        item: canonicalUrl
      }
    ]
  }
];

if (posts.length === 0) {
  throw new Error(`Category not found: ${category}`);
}
---
<BaseLayout
  title={`${categoryLabel} | Categories | OpenBlog`}
  description={pageDescription}
  canonicalPath={canonicalPath}
  structuredData={structuredData}
>
  <section class="card">
    <p class="kicker icon-label"><i class="ti ti-category icon-sm" aria-hidden="true"></i>Category</p>
    <h1>{categoryLabel}</h1>
    <p class="meta icon-label">
      <i class="ti ti-notes icon-sm" aria-hidden="true"></i>
      {posts.length} post{posts.length > 1 ? 's' : ''} available in this topic.
    </p>
  </section>

  <section class="list paginated-list">
    <p id="category-posts-page-info" class="meta pagination-info">Showing {postsPerPage} posts per page</p>
    <div class="post-grid" data-category-posts-per-page={postsPerPage}>
      {posts.map((post) => (
        <PostCard
          post={post}
          showCategory={false}
          dataAttribute="data-category-post-card"
        />
      ))}
    </div>

    {postsTotalPages > 1 && (
      <nav class="leaderboard-pagination" aria-label={`${categoryLabel} posts pages`}>
        <a id="category-posts-prev" class="page-control" href="?page=1">Previous</a>
        <ul class="page-links" aria-label="Page numbers">
          {postPageNumbers.map((page) => (
            <li>
              <a data-category-page-link={page} class="page-link" href={`?page=${page}`}>{page}</a>
            </li>
          ))}
        </ul>
        <a id="category-posts-next" class="page-control" href={`?page=${postsTotalPages > 1 ? 2 : 1}`}>Next</a>
      </nav>
    )}
  </section>

  <section class="card table-wrap">
    <h2 class="icon-label"><i class="ti ti-trophy icon-sm" aria-hidden="true"></i>{categoryLabel} leaderboard</h2>
    {categoryLeaderboard.length === 0 ? (
      <p class="meta">No scored contributions for this category yet.</p>
    ) : (
      <table class="table">
        <thead>
          <tr>
            <th scope="col">Rank</th>
            <th scope="col">User</th>
            <th scope="col">Points</th>
            <th scope="col">PRs</th>
          </tr>
        </thead>
        <tbody>
          {categoryLeaderboard.map((user, index) => (
            <tr>
              <td>#{index + 1}</td>
              <td>
                <a class="user-chip user-link" href={getProfilePath(user.username)}>
                  <UserAvatar username={user.username} avatarUrl={user.avatarUrl} size={80} />
                  <span class="user-handle">@{user.username}</span>
                </a>
              </td>
              <td>
                <span class="points-inline">
                  <i class="ti ti-sparkles icon-sm points-icon" aria-hidden="true"></i>
                  {user.totalPoints}
                </span>
              </td>
              <td>{user.acceptedPrs}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </section>

  <script is:inline>
    (function () {
      var cards = Array.from(document.querySelectorAll('[data-category-post-card]'));
      if (cards.length === 0) return;

      var grid = document.querySelector('[data-category-posts-per-page]');
      var perPage = Number((grid && grid.getAttribute('data-category-posts-per-page')) || '6');
      var pages = Math.max(1, Math.ceil(cards.length / perPage));
      var pageInfo = document.getElementById('category-posts-page-info');
      var prev = document.getElementById('category-posts-prev');
      var next = document.getElementById('category-posts-next');
      var pageLinks = Array.from(document.querySelectorAll('[data-category-page-link]'));

      var parsePage = function () {
        var params = new URLSearchParams(window.location.search);
        var pageParam = Number(params.get('page') || '1');
        if (!Number.isFinite(pageParam) || pageParam < 1) return 1;
        if (pageParam > pages) return pages;
        return Math.floor(pageParam);
      };

      var currentPage = parsePage();

      var setPageState = function (target, disabled) {
        if (!target) return;
        if (disabled) {
          target.setAttribute('aria-disabled', 'true');
          target.classList.add('is-disabled');
        } else {
          target.removeAttribute('aria-disabled');
          target.classList.remove('is-disabled');
        }
      };

      var syncUrl = function () {
        var url = new URL(window.location.href);
        if (currentPage === 1) {
          url.searchParams.delete('page');
        } else {
          url.searchParams.set('page', String(currentPage));
        }
        window.history.replaceState({}, '', url);
      };

      var render = function () {
        var start = (currentPage - 1) * perPage;
        var end = start + perPage;

        cards.forEach(function (card, index) {
          card.hidden = index < start || index >= end;
        });

        if (pageInfo) {
          pageInfo.textContent = 'Page ' + currentPage + ' of ' + pages + ' (' + cards.length + ' posts)';
        }

        pageLinks.forEach(function (link) {
          var page = Number(link.getAttribute('data-category-page-link'));
          var isActive = page === currentPage;
          if (isActive) {
            link.classList.add('is-active');
            link.setAttribute('aria-current', 'page');
          } else {
            link.classList.remove('is-active');
            link.removeAttribute('aria-current');
          }
        });

        if (prev) {
          prev.setAttribute('href', '?page=' + Math.max(1, currentPage - 1));
        }
        if (next) {
          next.setAttribute('href', '?page=' + Math.min(pages, currentPage + 1));
        }

        setPageState(prev, currentPage <= 1);
        setPageState(next, currentPage >= pages);
      };

      var goToPage = function (page) {
        if (page < 1 || page > pages || page === currentPage) return false;
        currentPage = page;
        render();
        syncUrl();
        return true;
      };

      pageLinks.forEach(function (link) {
        link.addEventListener('click', function (event) {
          var targetPage = Number(link.getAttribute('data-category-page-link')) || 1;
          if (targetPage === currentPage) {
            event.preventDefault();
            return;
          }
          if (goToPage(targetPage)) {
            event.preventDefault();
          }
        });
      });

      if (prev) {
        prev.addEventListener('click', function (event) {
          if (currentPage <= 1) {
            event.preventDefault();
            return;
          }
          if (goToPage(currentPage - 1)) {
            event.preventDefault();
          }
        });
      }

      if (next) {
        next.addEventListener('click', function (event) {
          if (currentPage >= pages) {
            event.preventDefault();
            return;
          }
          if (goToPage(currentPage + 1)) {
            event.preventDefault();
          }
        });
      }

      render();
      syncUrl();
    })();
  </script>

  <style>
    .leaderboard-pagination {
      margin-top: 0.45rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }

    .page-links {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
    }

    .page-control,
    .page-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 2rem;
      min-height: 2rem;
      border: 1px solid var(--border);
      background: var(--surface-soft);
      color: var(--text);
      font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      line-height: 1;
      padding: 0.35rem 0.55rem;
      text-decoration: none;
    }

    .page-link.is-active {
      text-decoration: underline;
      text-underline-offset: 0.2em;
    }

    .page-control.is-disabled {
      opacity: 0.55;
      pointer-events: none;
    }

    @media (max-width: 860px) {
      .leaderboard-pagination {
        justify-content: center;
      }
    }
  </style>
</BaseLayout>
