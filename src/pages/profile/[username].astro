---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import {
  getContributedPostSlugsByUser,
  getKnownContributors,
  getPostBySlug,
  getProfileContributionsPath,
  getProfilePath,
  getUserProfile
} from '../../lib/openblog';
import { toAbsoluteUrl } from '../../lib/seo';
import { getSiteUrl } from '../../lib/site';

export function getStaticPaths() {
  return getKnownContributors().map((username) => ({ params: { username: `@${username}` } }));
}

const routeUsername = Astro.params.username ?? '';
const normalizedUsername = routeUsername.replace(/^@+/, '');
const profile = getUserProfile(normalizedUsername);
if (!profile) {
  throw new Error('Profile not found');
}

const profileImageUrl = profile.avatarUrl ?? `https://github.com/${profile.username}.png?size=112`;
const latestPosts = getContributedPostSlugsByUser(profile.username)
  .map((postSlug) => getPostBySlug(postSlug))
  .filter((post): post is NonNullable<ReturnType<typeof getPostBySlug>> => Boolean(post));

const postsPerPage = 6;
const postsTotalPages = Math.max(1, Math.ceil(latestPosts.length / postsPerPage));
const postPageNumbers = Array.from({ length: postsTotalPages }, (_, index) => index + 1);
const formatDate = (isoDate: string | null) => {
  if (!isoDate) return 'N/A';
  const parsed = new Date(isoDate);
  return Number.isNaN(parsed.getTime()) ? isoDate : parsed.toISOString().slice(0, 10);
};
const canonicalPath = getProfilePath(profile.username);
const pageDescription = `View @${profile.username}'s OpenBlog profile, including contribution stats and latest posts.`;
const siteUrl = getSiteUrl(Astro.site);
const canonicalUrl = toAbsoluteUrl(canonicalPath, siteUrl);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  name: `@${profile.username} | OpenBlog`,
  description: pageDescription,
  url: canonicalUrl,
  mainEntity: {
    '@type': 'Person',
    name: profile.username,
    url: profile.profileUrl,
    image: profileImageUrl,
    sameAs: [profile.profileUrl]
  }
};
---
<BaseLayout
  title={`@${profile.username} | OpenBlog`}
  description={pageDescription}
  canonicalPath={canonicalPath}
  ogType="profile"
  structuredData={structuredData}
>
  <section class="card">
    <div class="profile-head">
      <a
        class="profile-avatar-link"
        href={profile.profileUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Open @${profile.username} GitHub profile`}
      >
        <img
          class="avatar profile-avatar"
          src={profileImageUrl}
          alt={`@${profile.username} avatar`}
          loading="lazy"
          width="128"
          height="128"
        />
        <span class="profile-avatar-overlay" aria-hidden="true">
          <i class="ti ti-external-link icon-sm" aria-hidden="true"></i>
        </span>
      </a>
      <div class="profile-copy">
        <p class="kicker icon-label"><i class="ti ti-user-circle icon-sm" aria-hidden="true"></i>Contributor profile</p>
        <h1>@{profile.username}</h1>
        <p class="meta profile-meta">
          <span class="icon-label"><i class="ti ti-calendar-plus icon-sm" aria-hidden="true"></i>Joined: {formatDate(profile.joinedAt)}</span>
          <span class="icon-label"><i class="ti ti-clock icon-sm" aria-hidden="true"></i>Last contribution: {formatDate(profile.lastContributionAt)}</span>
        </p>
        <p class="profile-links">
          <a class="sidebar-link" href={profile.profileUrl} target="_blank" rel="noopener noreferrer">
            <i class="ti ti-brand-github icon-sm" aria-hidden="true"></i>
            GitHub profile
          </a>
          <a class="sidebar-link" href={getProfileContributionsPath(profile.username)}>
            <i class="ti ti-list-details icon-sm" aria-hidden="true"></i>
            Contribution details
          </a>
          <a class="sidebar-link" href="/leaderboard">
            <i class="ti ti-trophy icon-sm" aria-hidden="true"></i>
            Back to leaderboard
          </a>
        </p>
      </div>
    </div>
  </section>

  <section class="card">
    <h2 class="icon-label"><i class="ti ti-chart-bar icon-sm" aria-hidden="true"></i>Contribution stats</h2>
    <div class="stats profile-stats">
      <div class="stat">
        <span class="stat-head icon-label"><i class="ti ti-sparkles icon-sm points-icon" aria-hidden="true"></i><span class="stat-value">{profile.totalPoints}</span></span>
        <span class="stat-label">Total points</span>
      </div>
      <div class="stat">
        <span class="stat-head icon-label"><i class="ti ti-git-merge icon-sm" aria-hidden="true"></i><span class="stat-value">{profile.acceptedPrs}</span></span>
        <span class="stat-label">Accepted PRs</span>
      </div>
      <div class="stat">
        <span class="stat-head icon-label"><i class="ti ti-article icon-sm" aria-hidden="true"></i><span class="stat-value">{profile.postsContributed}</span></span>
        <span class="stat-label">Posts contributed</span>
      </div>
      <div class="stat">
        <span class="stat-head icon-label"><i class="ti ti-list-numbers icon-sm" aria-hidden="true"></i><span class="stat-value">{profile.totalContributions}</span></span>
        <span class="stat-label">Total contribution entries</span>
      </div>
    </div>
  </section>

  <section class="list paginated-list">
    <p class="kicker icon-label"><i class="ti ti-notes icon-sm" aria-hidden="true"></i>Latest posts</p>
    <p id="profile-latest-posts-page-info" class="meta pagination-info">Showing {postsPerPage} posts per page</p>

    {latestPosts.length === 0 ? (
      <article class="card">
        <h2>No latest posts yet</h2>
        <p class="meta">No published post links are available for this contributor yet.</p>
      </article>
    ) : (
      <>
        <div class="post-grid" data-profile-posts-per-page={postsPerPage}>
          {latestPosts.map((post) => (
            <PostCard
              post={post}
              dataAttribute="data-profile-latest-post-card"
            />
          ))}
        </div>

        <nav class="leaderboard-pagination" aria-label="Profile latest posts pages">
          <a id="profile-latest-posts-prev" class="page-control" href="?page=1">Previous</a>
          <ul class="page-links" aria-label="Page numbers">
            {postPageNumbers.map((page) => (
              <li>
                <a data-profile-latest-page-link={page} class="page-link" href={`?page=${page}`}>{page}</a>
              </li>
            ))}
          </ul>
          <a id="profile-latest-posts-next" class="page-control" href={`?page=${postsTotalPages > 1 ? 2 : 1}`}>Next</a>
        </nav>
      </>
    )}
  </section>

  <script is:inline>
    (function () {
      var cards = Array.from(document.querySelectorAll('[data-profile-latest-post-card]'));
      if (cards.length === 0) return;

      var grid = document.querySelector('[data-profile-posts-per-page]');
      var perPage = Number((grid && grid.getAttribute('data-profile-posts-per-page')) || '6');
      var pages = Math.max(1, Math.ceil(cards.length / perPage));
      var pageInfo = document.getElementById('profile-latest-posts-page-info');
      var prev = document.getElementById('profile-latest-posts-prev');
      var next = document.getElementById('profile-latest-posts-next');
      var pageLinks = Array.from(document.querySelectorAll('[data-profile-latest-page-link]'));

      var parsePage = function () {
        var params = new URLSearchParams(window.location.search);
        var pageParam = Number(params.get('page') || '1');
        if (!Number.isFinite(pageParam) || pageParam < 1) return 1;
        if (pageParam > pages) return pages;
        return Math.floor(pageParam);
      };

      var currentPage = parsePage();

      var setPageState = function (target, disabled) {
        if (!target) return;
        if (disabled) {
          target.setAttribute('aria-disabled', 'true');
          target.classList.add('is-disabled');
        } else {
          target.removeAttribute('aria-disabled');
          target.classList.remove('is-disabled');
        }
      };

      var syncUrl = function () {
        var url = new URL(window.location.href);
        if (currentPage === 1) {
          url.searchParams.delete('page');
        } else {
          url.searchParams.set('page', String(currentPage));
        }
        window.history.replaceState({}, '', url);
      };

      var render = function () {
        var start = (currentPage - 1) * perPage;
        var end = start + perPage;

        cards.forEach(function (card, index) {
          card.hidden = index < start || index >= end;
        });

        if (pageInfo) {
          pageInfo.textContent = 'Page ' + currentPage + ' of ' + pages + ' (' + cards.length + ' posts)';
        }

        pageLinks.forEach(function (link) {
          var page = Number(link.getAttribute('data-profile-latest-page-link'));
          var isActive = page === currentPage;
          if (isActive) {
            link.classList.add('is-active');
            link.setAttribute('aria-current', 'page');
          } else {
            link.classList.remove('is-active');
            link.removeAttribute('aria-current');
          }
        });

        if (prev) {
          prev.setAttribute('href', '?page=' + Math.max(1, currentPage - 1));
        }
        if (next) {
          next.setAttribute('href', '?page=' + Math.min(pages, currentPage + 1));
        }

        setPageState(prev, currentPage <= 1);
        setPageState(next, currentPage >= pages);
      };

      var goToPage = function (page) {
        if (page < 1 || page > pages || page === currentPage) return false;
        currentPage = page;
        render();
        syncUrl();
        return true;
      };

      pageLinks.forEach(function (link) {
        link.addEventListener('click', function (event) {
          var targetPage = Number(link.getAttribute('data-profile-latest-page-link')) || 1;
          if (targetPage === currentPage) {
            event.preventDefault();
            return;
          }
          if (goToPage(targetPage)) {
            event.preventDefault();
          }
        });
      });

      if (prev) {
        prev.addEventListener('click', function (event) {
          if (currentPage <= 1) {
            event.preventDefault();
            return;
          }
          if (goToPage(currentPage - 1)) {
            event.preventDefault();
          }
        });
      }

      if (next) {
        next.addEventListener('click', function (event) {
          if (currentPage >= pages) {
            event.preventDefault();
            return;
          }
          if (goToPage(currentPage + 1)) {
            event.preventDefault();
          }
        });
      }

      render();
      syncUrl();
    })();
  </script>

  <style>
    .profile-head {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
      align-items: center;
    }

    .profile-avatar {
      width: 8rem;
      height: 8rem;
      border-radius: 50%;
    }

    .profile-avatar-link {
      position: relative;
      display: inline-flex;
      flex: 0 0 auto;
      color: var(--surface);
      text-decoration: none;
      line-height: 1;
    }

    .profile-avatar-overlay {
      position: absolute;
      inset: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: color-mix(in srgb, var(--text) 55%, transparent);
      opacity: 0;
      transition: opacity 140ms ease;
      border-radius: 50%;
    }

    .profile-avatar-link:hover .profile-avatar-overlay,
    .profile-avatar-link:focus-visible .profile-avatar-overlay {
      opacity: 1;
    }

    .profile-copy {
      display: grid;
      gap: 0.35rem;
      min-width: 0;
    }

    .profile-copy h1 {
      margin-bottom: 0;
    }

    .profile-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-bottom: 0;
    }

    .profile-links {
      margin: 0.1rem 0 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .profile-stats {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .leaderboard-pagination {
      margin-top: 0.45rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }

    .page-links {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
    }

    .page-control,
    .page-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 2rem;
      min-height: 2rem;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--surface);
      color: var(--text);
      font-family: var(--font-main);
      font-size: 0.82rem;
      font-weight: 600;
      line-height: 1;
      padding: 0.35rem 0.55rem;
      text-decoration: none;
    }

    .page-link.is-active {
      border-color: var(--primary);
      background: var(--surface-soft);
      color: var(--primary);
      text-decoration: none;
    }

    .page-control.is-disabled {
      opacity: 0.55;
      pointer-events: none;
    }

    @media (max-width: 860px) {
      .profile-stats {
        grid-template-columns: 1fr;
      }

      .leaderboard-pagination {
        justify-content: center;
      }
    }
  </style>
</BaseLayout>
