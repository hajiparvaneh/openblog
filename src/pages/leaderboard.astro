---
import BaseLayout from '../layouts/BaseLayout.astro';
import UserAvatar from '../components/UserAvatar.astro';
import { getLeaderboard, getPosts, getRecentEvents, getUserPostContributionCounts } from '../lib/openblog';
import { toAbsoluteUrl } from '../lib/seo';
import { getSiteUrl } from '../lib/site';

const leaderboard = getLeaderboard();
const recentEvents = getRecentEvents(10);
const postSlugs = new Set(getPosts().map((post) => post.slug));
const postContributionCounts = getUserPostContributionCounts();
const rowsPerPage = 10;
const totalPages = Math.max(1, Math.ceil(leaderboard.length / rowsPerPage));
const pageNumbers = Array.from({ length: totalPages }, (_, index) => index + 1);
const getProfileUrl = (username: string) => `/profile/@${username}`;
const getPullRequestUrl = (prNumber: number) => `https://github.com/hajiparvaneh/openblog/pull/${prNumber}`;
const getPostUrl = (postSlug: string) => (postSlugs.has(postSlug) ? `/posts/${postSlug}` : null);
const pageDescription =
  'See the OpenBlog contributor leaderboard ranked by points and merged pull requests, plus the latest accepted contributions.';
const canonicalPath = '/leaderboard';
const siteUrl = getSiteUrl(Astro.site);
const canonicalUrl = toAbsoluteUrl(canonicalPath, siteUrl);
const topContributors = leaderboard.slice(0, 10);
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'OpenBlog Leaderboard',
    description: pageDescription,
    url: canonicalUrl
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'OpenBlog Top Contributors',
    itemListElement: topContributors.map((user, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: toAbsoluteUrl(getProfileUrl(user.username), siteUrl),
      name: `@${user.username}`
    }))
  }
];
---
<BaseLayout title="Leaderboard | OpenBlog" description={pageDescription} canonicalPath={canonicalPath} structuredData={structuredData}>
  <section class="card">
    <p class="kicker icon-label"><i class="ti ti-chart-bar icon-sm" aria-hidden="true"></i>Community scoreboard</p>
    <h1>Leaderboard</h1>
    <p class="meta">Ranks are sorted by total points, then merged PR count.</p>
  </section>

  <section class="card table-wrap">
    <h2 class="icon-label"><i class="ti ti-list-numbers icon-sm" aria-hidden="true"></i>Contributor rankings</h2>
    <p id="leaderboard-page-info" class="meta">Showing {rowsPerPage} users per page</p>

    <table class="table" id="leaderboard-table" data-per-page={rowsPerPage}>
      <thead>
        <tr>
          <th scope="col" data-sort-column="rank">
            <button class="table-sort-button" data-sort-key="rank" type="button">
              Rank
              <span class="sort-indicator" data-sort-indicator aria-hidden="true">↕</span>
            </button>
          </th>
          <th scope="col" data-sort-column="user">
            <button class="table-sort-button" data-sort-key="user" type="button">
              User
              <span class="sort-indicator" data-sort-indicator aria-hidden="true">↕</span>
            </button>
          </th>
          <th scope="col" data-sort-column="points">
            <button class="table-sort-button" data-sort-key="points" type="button">
              Points
              <span class="sort-indicator" data-sort-indicator aria-hidden="true">↕</span>
            </button>
          </th>
          <th scope="col" data-sort-column="posts">
            <button class="table-sort-button" data-sort-key="posts" type="button">
              Posts contributed
              <span class="sort-indicator" data-sort-indicator aria-hidden="true">↕</span>
            </button>
          </th>
        </tr>
      </thead>
      <tbody>
        {leaderboard.map((user, index) => {
          const postsContributed = postContributionCounts[user.username] ?? 0;

          return (
          <tr
            data-leaderboard-row
            data-rank={index + 1}
            data-user={user.username.toLowerCase()}
            data-points={user.totalPoints}
            data-posts={postsContributed}
          >
            <td>#{index + 1}</td>
            <td>
              <a class="user-chip user-link" href={getProfileUrl(user.username)}>
                <UserAvatar username={user.username} avatarUrl={user.avatarUrl} size={80} />
                <span class="user-handle">@{user.username}</span>
              </a>
            </td>
            <td>
              <span class="points-inline">
                <i class="ti ti-sparkles icon-sm points-icon" aria-hidden="true"></i>
                {user.totalPoints}
              </span>
            </td>
            <td>{postsContributed}</td>
          </tr>
          );
        })}
      </tbody>
    </table>

    {totalPages > 1 && (
      <nav class="leaderboard-pagination" aria-label="Leaderboard pages">
        <a id="leaderboard-prev" class="page-control" href="/leaderboard?page=1">Previous</a>
        <ul class="page-links" aria-label="Page numbers">
          {pageNumbers.map((page) => (
            <li>
              <a data-page-link={page} class="page-link" href={`/leaderboard?page=${page}`}>{page}</a>
            </li>
          ))}
        </ul>
        <a id="leaderboard-next" class="page-control" href={`/leaderboard?page=${totalPages > 1 ? 2 : 1}`}>Next</a>
      </nav>
    )}
  </section>

  <section class="card">
    <h2 class="icon-label"><i class="ti ti-git-pull-request icon-sm" aria-hidden="true"></i>Recent contributions</h2>
    <ul class="recent-list">
      {recentEvents.map((event) => {
        const postUrl = getPostUrl(event.postSlug);

        return (
          <li class="recent-item">
            <span class="icon-label"><i class="ti ti-git-pull-request icon-sm" aria-hidden="true"></i><a href={getPullRequestUrl(event.prNumber)} target="_blank" rel="noopener noreferrer">PR #{event.prNumber}</a> by</span>
            <a class="user-chip user-link" href={getProfileUrl(event.username)}>
              <UserAvatar username={event.username} avatarUrl={event.userAvatarUrl} size={64} class="avatar-sm" />
              <span class="user-handle">@{event.username}</span>
            </a>
            <span>
              <span class="icon-label"><i class="ti ti-article icon-sm" aria-hidden="true"></i>{postUrl ? <a href={postUrl}>{event.postSlug}</a> : <span>unknown post</span>}</span> <span class="badge points-badge"><i class="ti ti-sparkles icon-sm points-icon" aria-hidden="true"></i>+{event.points}</span>
            </span>
          </li>
        );
      })}
    </ul>
  </section>

  <script is:inline>
    (function () {
      var table = document.getElementById('leaderboard-table');
      if (!table) return;

      var tbody = table.querySelector('tbody');
      if (!tbody) return;

      var rows = Array.from(tbody.querySelectorAll('[data-leaderboard-row]'));
      var perPage = Number(table.getAttribute('data-per-page') || '10');
      var pages = Math.max(1, Math.ceil(rows.length / perPage));
      var pageInfo = document.getElementById('leaderboard-page-info');
      var prev = document.getElementById('leaderboard-prev');
      var next = document.getElementById('leaderboard-next');
      var pageLinks = Array.from(document.querySelectorAll('[data-page-link]'));
      var sortButtons = Array.from(table.querySelectorAll('[data-sort-key]'));
      var sortColumns = Array.from(table.querySelectorAll('[data-sort-column]'));
      var collator = new Intl.Collator(undefined, { sensitivity: 'base', numeric: true });

      var parsePage = function () {
        var params = new URLSearchParams(window.location.search);
        var pageParam = Number(params.get('page') || '1');
        if (!Number.isFinite(pageParam) || pageParam < 1) return 1;
        if (pageParam > pages) return pages;
        return Math.floor(pageParam);
      };

      var currentPage = parsePage();
      var sortState = { key: 'rank', direction: 'asc' };

      var getRowValue = function (row, key) {
        if (key === 'user') return row.getAttribute('data-user') || '';
        if (key === 'points') return Number(row.getAttribute('data-points') || '0');
        if (key === 'posts') return Number(row.getAttribute('data-posts') || '0');
        return Number(row.getAttribute('data-rank') || '0');
      };

      var sortRows = function () {
        rows.sort(function (a, b) {
          var aValue = getRowValue(a, sortState.key);
          var bValue = getRowValue(b, sortState.key);
          var result;

          if (typeof aValue === 'string' || typeof bValue === 'string') {
            result = collator.compare(String(aValue), String(bValue));
          } else {
            result = Number(aValue) - Number(bValue);
          }

          if (result === 0 && sortState.key !== 'rank') {
            result = Number(a.getAttribute('data-rank') || '0') - Number(b.getAttribute('data-rank') || '0');
          }

          return sortState.direction === 'asc' ? result : -result;
        });

        rows.forEach(function (row) {
          tbody.appendChild(row);
        });
      };

      var updateSortUi = function () {
        sortColumns.forEach(function (column) {
          var key = column.getAttribute('data-sort-column');
          var isCurrent = key === sortState.key;
          column.setAttribute('aria-sort', isCurrent ? (sortState.direction === 'asc' ? 'ascending' : 'descending') : 'none');
        });

        sortButtons.forEach(function (button) {
          var key = button.getAttribute('data-sort-key');
          var indicator = button.querySelector('[data-sort-indicator]');
          var isCurrent = key === sortState.key;
          if (!indicator) return;
          indicator.textContent = isCurrent ? (sortState.direction === 'asc' ? '↑' : '↓') : '↕';
        });
      };

      var syncUrl = function () {
        var url = new URL(window.location.href);
        if (currentPage === 1) {
          url.searchParams.delete('page');
        } else {
          url.searchParams.set('page', String(currentPage));
        }
        window.history.replaceState({}, '', url);
      };

      var setPageState = function (target, disabled) {
        if (!target) return;
        if (disabled) {
          target.setAttribute('aria-disabled', 'true');
          target.classList.add('is-disabled');
        } else {
          target.removeAttribute('aria-disabled');
          target.classList.remove('is-disabled');
        }
      };

      var render = function () {
        var start = (currentPage - 1) * perPage;
        var end = start + perPage;

        rows.forEach(function (row, index) {
          row.hidden = index < start || index >= end;
        });

        if (pageInfo) {
          pageInfo.textContent = 'Page ' + currentPage + ' of ' + pages + ' (' + rows.length + ' contributors)';
        }

        pageLinks.forEach(function (link) {
          var page = Number(link.getAttribute('data-page-link'));
          var isActive = page === currentPage;
          if (isActive) {
            link.classList.add('is-active');
            link.setAttribute('aria-current', 'page');
          } else {
            link.classList.remove('is-active');
            link.removeAttribute('aria-current');
          }
        });

        if (prev) {
          prev.setAttribute('href', '/leaderboard?page=' + Math.max(1, currentPage - 1));
        }
        if (next) {
          next.setAttribute('href', '/leaderboard?page=' + Math.min(pages, currentPage + 1));
        }

        setPageState(prev, currentPage <= 1);
        setPageState(next, currentPage >= pages);
      };

      var goToPage = function (page) {
        if (page < 1 || page > pages || page === currentPage) return;
        currentPage = page;
        render();
        syncUrl();
      };

      sortButtons.forEach(function (button) {
        button.addEventListener('click', function () {
          var key = button.getAttribute('data-sort-key');
          if (!key) return;

          if (sortState.key === key) {
            sortState.direction = sortState.direction === 'asc' ? 'desc' : 'asc';
          } else {
            sortState.key = key;
            sortState.direction = 'asc';
          }

          currentPage = 1;
          sortRows();
          updateSortUi();
          render();
          syncUrl();
        });
      });

      pageLinks.forEach(function (link) {
        link.addEventListener('click', function (event) {
          event.preventDefault();
          goToPage(Number(link.getAttribute('data-page-link')) || 1);
        });
      });

      if (prev) {
        prev.addEventListener('click', function (event) {
          if (currentPage <= 1) {
            event.preventDefault();
            return;
          }
          event.preventDefault();
          goToPage(currentPage - 1);
        });
      }

      if (next) {
        next.addEventListener('click', function (event) {
          if (currentPage >= pages) {
            event.preventDefault();
            return;
          }
          event.preventDefault();
          goToPage(currentPage + 1);
        });
      }

      sortRows();
      updateSortUi();
      render();
      syncUrl();
    })();
  </script>

  <style>
    .table-sort-button {
      display: inline-flex;
      align-items: center;
      justify-content: flex-start;
      gap: 0.25rem;
      width: 100%;
      border: 0;
      background: transparent;
      color: inherit;
      font: inherit;
      letter-spacing: inherit;
      text-transform: inherit;
      cursor: pointer;
      padding: 0;
    }

    .sort-indicator {
      font-size: 0.74rem;
      line-height: 1;
    }

    .leaderboard-pagination {
      margin-top: 0.8rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }

    .page-links {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
    }

    .page-control,
    .page-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 2rem;
      min-height: 2rem;
      border: 1px solid var(--border);
      background: var(--surface-soft);
      color: var(--text);
      font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      line-height: 1;
      padding: 0.35rem 0.55rem;
      text-decoration: none;
    }

    .page-link.is-active {
      text-decoration: underline;
      text-underline-offset: 0.2em;
    }

    .page-control.is-disabled {
      opacity: 0.55;
      pointer-events: none;
    }

    @media (max-width: 860px) {
      .leaderboard-pagination {
        justify-content: center;
      }
    }
  </style>
</BaseLayout>
