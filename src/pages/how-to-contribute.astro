---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';

const scoreByLabelPath = path.join(process.cwd(), 'game/enums/scoring-labels.json');
const scoreByLabel = JSON.parse(fs.readFileSync(scoreByLabelPath, 'utf8')) as Record<string, number>;
const sortedScoringRules = Object.entries(scoreByLabel).sort(([, pointsA], [, pointsB]) => pointsA - pointsB);
---
<BaseLayout title="How to contribute | OpenBlog">
  <h1>How to contribute</h1>
  <ol class="card">
    <li>Choose a post from <code>/content/posts/&lt;category&gt;/&lt;post&gt;.md</code> and improve it (fix typo, add source, fact-check, add examples, translation, or new post).</li>
    <li>Open a pull request that clearly explains the improvement and references the changed post slug (for example <code>networking/how-dns-works</code>).</li>
    <li>Maintainers review your PR, apply one or more scoring labels, and merge if accepted.</li>
    <li>After merge, the score workflow creates a game event and regenerates leaderboard files.</li>
    <li>Your points are added automatically based on the labels on the merged PR.</li>
  </ol>

  <h2>Scoring labels (enum)</h2>
  <ul class="card">
    {sortedScoringRules.map(([label, points]) => (
      <li><code>{label}</code>: +{points} points</li>
    ))}
  </ul>

  <h2>Rules</h2>
  <ul class="card">
    <li>Only merged PRs are eligible for points.</li>
    <li>At least one scoring label is required to generate an event.</li>
    <li>If a PR has multiple scoring labels, all label points are summed.</li>
    <li>Leaderboard rank is sorted by total points (desc), then accepted PR count (desc).</li>
  </ul>
</BaseLayout>
