---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { formatPostDate, getCategoryPath, getLatestContributorByPost, getLatestContributorsForPost, getPosts, getProfilePath } from '../lib/openblog';
import { toAbsoluteUrl } from '../lib/seo';
import { getSiteUrl } from '../lib/site';

const posts = getPosts();
const latestPost = posts[0];
const remainingPosts = posts
  .slice(1)
  .sort((a, b) => b.date.localeCompare(a.date) || a.slug.localeCompare(b.slug));
const postsPerPage = 6;
const postsTotalPages = Math.max(1, Math.ceil(remainingPosts.length / postsPerPage));
const postPageNumbers = Array.from({ length: postsTotalPages }, (_, index) => index + 1);
const categoryCount = new Set(posts.map((post) => post.category)).size;
const latestContributorByPost = getLatestContributorByPost();
const latestContributors = latestPost ? getLatestContributorsForPost(latestPost.slug, 5) : [];
const getAvatarUrl = (username: string, avatarUrl?: string | null) =>
  avatarUrl ?? `https://github.com/${username}.png?size=64`;
const pageDescription =
  'OpenBlog is a collaborative technical blog where merged pull requests improve articles and contributors earn points on a public leaderboard.';
const canonicalPath = '/';
const siteUrl = getSiteUrl(Astro.site);
const canonicalUrl = toAbsoluteUrl(canonicalPath, siteUrl);
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'OpenBlog',
    description: pageDescription,
    url: toAbsoluteUrl('/', siteUrl)
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'OpenBlog Home',
    description: pageDescription,
    url: canonicalUrl
  }
];
---
<BaseLayout title="OpenBlog | Collaborative Technical Blog" description={pageDescription} canonicalPath={canonicalPath} structuredData={structuredData}>
  <section class="card hero">
    <p class="kicker icon-label"><i class="ti ti-news icon-sm" aria-hidden="true"></i>Open source publication</p>
    <h1>Write and improve posts together.</h1>
    <p class="meta">Every accepted pull request improves the content and awards points on the public leaderboard.</p>
    <div class="stats">
      <div class="stat">
        <span class="stat-value stat-head"><i class="ti ti-notes icon-sm" aria-hidden="true"></i>{posts.length}</span>
        <span class="stat-label">Published posts</span>
      </div>
      <div class="stat">
        <span class="stat-value stat-head"><i class="ti ti-category icon-sm" aria-hidden="true"></i>{categoryCount}</span>
        <span class="stat-label">Active categories</span>
      </div>
      <div class="stat">
        <span class="stat-value stat-head"><i class="ti ti-git-pull-request icon-sm" aria-hidden="true"></i>PR-based</span>
        <span class="stat-label">Contribution model</span>
      </div>
    </div>
  </section>

  {latestPost ? (
    <section class="card post-card latest-post-card">
      <a class="category-link latest-post-category" href={getCategoryPath(latestPost.category)}>
        <i class="ti ti-category icon-sm" aria-hidden="true"></i>
        {latestPost.categoryLabel}
      </a>
      <p class="kicker icon-label"><i class="ti ti-clock-hour-4 icon-sm" aria-hidden="true"></i>Latest post</p>
      <h2><a href={`/posts/${latestPost.slug}`}>{latestPost.title}</a></h2>
      <p>{latestPost.description}</p>
      <p class="meta meta-inline">
        {latestContributors.length > 0 ? (
          <span class="meta-item latest-post-contributors-inline">
            <span class="latest-post-contributors-list">
              {latestContributors.map((contributor) => (
                <a
                  class="user-chip user-link latest-post-contributor-inline"
                  href={getProfilePath(contributor.username)}
                  aria-label={`@${contributor.username}`}
                  title={`@${contributor.username}`}
                >
                  <img
                    class="avatar avatar-sm"
                    src={getAvatarUrl(contributor.username, contributor.avatarUrl)}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    width="24"
                    height="24"
                  />
                  <span class="latest-post-contributor-name">@{contributor.username}</span>
                </a>
              ))}
            </span>
          </span>
        ) : null}
        <span class="meta-item"><i class="ti ti-calendar icon-sm" aria-hidden="true"></i>{formatPostDate(latestPost.date)}</span>
      </p>
    </section>
  ) : null}

  {remainingPosts.length > 0 ? (
    <section class="list">
      <p class="kicker icon-label"><i class="ti ti-list icon-sm" aria-hidden="true"></i>Browse all stories</p>
      <p id="home-posts-page-info" class="meta">Showing {postsPerPage} posts per page</p>
      <div class="post-grid">
        {remainingPosts.map((post) => (
          <PostCard
            post={post}
            author={latestContributorByPost.get(post.slug)}
            dataAttribute="data-home-post-card"
            dateSortValue={post.date}
          />
        ))}
      </div>

      {postsTotalPages > 1 && (
        <nav class="leaderboard-pagination" aria-label="Homepage posts pages">
          <a id="home-posts-prev" class="page-control" href="?page=1">Previous</a>
          <ul class="page-links" aria-label="Page numbers">
            {postPageNumbers.map((page) => (
              <li>
                <a data-home-page-link={page} class="page-link" href={`?page=${page}`}>{page}</a>
              </li>
            ))}
          </ul>
          <a id="home-posts-next" class="page-control" href={`?page=${postsTotalPages > 1 ? 2 : 1}`}>Next</a>
        </nav>
      )}
    </section>
  ) : (
    <section class="list">
      <p class="kicker icon-label"><i class="ti ti-list icon-sm" aria-hidden="true"></i>Browse all stories</p>
      <article class="card">
        <h2>More stories are on the way</h2>
        <p class="meta">Only one post is available right now. More coming soon.</p>
      </article>
    </section>
  )}

  <script is:inline>
    (function () {
      var cards = Array.from(document.querySelectorAll('[data-home-post-card]'));
      if (cards.length === 0) return;
      var grid = document.querySelector('.post-grid');

      cards.sort(function (a, b) {
        var aDate = a.getAttribute('data-post-date') || '';
        var bDate = b.getAttribute('data-post-date') || '';
        if (aDate !== bDate) return bDate.localeCompare(aDate);

        var aHref = (a.querySelector('h2 a') && a.querySelector('h2 a').getAttribute('href')) || '';
        var bHref = (b.querySelector('h2 a') && b.querySelector('h2 a').getAttribute('href')) || '';
        return aHref.localeCompare(bHref);
      });

      if (grid) {
        cards.forEach(function (card) {
          grid.appendChild(card);
        });
      }

      var perPage = {postsPerPage};
      var pages = Math.max(1, Math.ceil(cards.length / perPage));
      var pageInfo = document.getElementById('home-posts-page-info');
      var prev = document.getElementById('home-posts-prev');
      var next = document.getElementById('home-posts-next');
      var pageLinks = Array.from(document.querySelectorAll('[data-home-page-link]'));

      var parsePage = function () {
        var params = new URLSearchParams(window.location.search);
        var pageParam = Number(params.get('page') || '1');
        if (!Number.isFinite(pageParam) || pageParam < 1) return 1;
        if (pageParam > pages) return pages;
        return Math.floor(pageParam);
      };

      var currentPage = parsePage();

      var setPageState = function (target, disabled) {
        if (!target) return;
        if (disabled) {
          target.setAttribute('aria-disabled', 'true');
          target.classList.add('is-disabled');
        } else {
          target.removeAttribute('aria-disabled');
          target.classList.remove('is-disabled');
        }
      };

      var syncUrl = function () {
        var url = new URL(window.location.href);
        if (currentPage === 1) {
          url.searchParams.delete('page');
        } else {
          url.searchParams.set('page', String(currentPage));
        }
        window.history.replaceState({}, '', url);
      };

      var render = function () {
        var start = (currentPage - 1) * perPage;
        var end = start + perPage;

        cards.forEach(function (card, index) {
          card.hidden = index < start || index >= end;
        });

        if (pageInfo) {
          pageInfo.textContent = 'Page ' + currentPage + ' of ' + pages + ' (' + cards.length + ' posts)';
        }

        pageLinks.forEach(function (link) {
          var page = Number(link.getAttribute('data-home-page-link'));
          var isActive = page === currentPage;
          if (isActive) {
            link.classList.add('is-active');
            link.setAttribute('aria-current', 'page');
          } else {
            link.classList.remove('is-active');
            link.removeAttribute('aria-current');
          }
        });

        if (prev) {
          prev.setAttribute('href', '?page=' + Math.max(1, currentPage - 1));
        }
        if (next) {
          next.setAttribute('href', '?page=' + Math.min(pages, currentPage + 1));
        }

        setPageState(prev, currentPage <= 1);
        setPageState(next, currentPage >= pages);
      };

      var goToPage = function (page) {
        if (page < 1 || page > pages || page === currentPage) return;
        currentPage = page;
        render();
        syncUrl();
      };

      pageLinks.forEach(function (link) {
        link.addEventListener('click', function (event) {
          event.preventDefault();
          goToPage(Number(link.getAttribute('data-home-page-link')) || 1);
        });
      });

      if (prev) {
        prev.addEventListener('click', function (event) {
          if (currentPage <= 1) {
            event.preventDefault();
            return;
          }
          event.preventDefault();
          goToPage(currentPage - 1);
        });
      }

      if (next) {
        next.addEventListener('click', function (event) {
          if (currentPage >= pages) {
            event.preventDefault();
            return;
          }
          event.preventDefault();
          goToPage(currentPage + 1);
        });
      }

      render();
      syncUrl();
    })();
  </script>

  <style>
    .leaderboard-pagination {
      margin-top: 0.8rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }

    .page-links {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
    }

    .page-control,
    .page-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 2rem;
      min-height: 2rem;
      border: 1px solid var(--border);
      background: var(--surface-soft);
      color: var(--text);
      font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      line-height: 1;
      padding: 0.35rem 0.55rem;
      text-decoration: none;
    }

    .page-link.is-active {
      text-decoration: underline;
      text-underline-offset: 0.2em;
    }

    .page-control.is-disabled {
      opacity: 0.55;
      pointer-events: none;
    }

    @media (max-width: 860px) {
      .leaderboard-pagination {
        justify-content: center;
      }
    }
  </style>
</BaseLayout>
