---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturedPostsSlider from '../components/FeaturedPostsSlider.astro';
import LatestPostCard from '../components/LatestPostCard.astro';
import PostCard from '../components/PostCard.astro';
import UserAvatar from '../components/UserAvatar.astro';
import {
  getCategoryPath,
  getLatestContributors,
  getLeaderboardByWindowWithFallback,
  getPosts,
  getProfilePath,
  getRecentEvents,
  getTagPath,
  getTagRecords
} from '../lib/openblog';
import { toAbsoluteUrl } from '../lib/seo';
import { getSiteUrl } from '../lib/site';

const posts = getPosts();
const latestPost = posts[0];
const CATEGORY_INSIGHTS_LIMIT = 8;
const TAGS_LIMIT = 20;
const TOP_CONTRIBUTORS_LIMIT = 5;
const LATEST_CONTRIBUTORS_LIMIT = 8;
const RECENT_EVENTS_LIMIT = 8;
const HOME_EVENTS_WINDOW_LIMIT = 24;
const remainingPosts = posts
  .slice(1)
  .sort((a, b) => b.date.localeCompare(a.date) || a.slug.localeCompare(b.slug));
const postsPerPage = 6;
const postsTotalPages = Math.max(1, Math.ceil(remainingPosts.length / postsPerPage));
const currentPage = 1;
const pageStart = (currentPage - 1) * postsPerPage;
const paginatedPosts = remainingPosts.slice(pageStart, pageStart + postsPerPage);
const postPageNumbers = Array.from({ length: postsTotalPages }, (_, index) => index + 1);
const categoryCount = new Set(posts.map((post) => post.category)).size;
const featuredPostCount = posts.filter((post) => post.featured).length;
const tagRecords = getTagRecords().sort((a, b) => b.postCount - a.postCount || a.label.localeCompare(b.label));
const topTags = tagRecords.slice(0, TAGS_LIMIT);
const tagCount = tagRecords.length;
const leaderboardResult = getLeaderboardByWindowWithFallback('month');
const leaderboard = leaderboardResult.entries;
const isAllTimeContributors = leaderboardResult.resolvedWindow === 'all';
const contributorsStatLabel = isAllTimeContributors ? 'All-time contributors' : 'Monthly contributors';
const topContributorsTitle = isAllTimeContributors ? 'Top contributors (all time)' : 'Top contributors this month';
const topContributorsDescription = isAllTimeContributors
  ? 'Ranked by points across all recorded contributions.'
  : 'Ranked by points in the current month.';
const topContributorsEmptyState = isAllTimeContributors
  ? 'Leaderboard data is not available yet.'
  : 'Monthly leaderboard data is not available yet.';
const hiddenContributorsLabel = isAllTimeContributors ? 'more contributors overall' : 'more contributors this month';
const totalContributors = leaderboard.length;
const topContributors = leaderboard.slice(0, TOP_CONTRIBUTORS_LIMIT);
const latestContributors = getLatestContributors(LATEST_CONTRIBUTORS_LIMIT);
const allRecentEvents = getRecentEvents(HOME_EVENTS_WINDOW_LIMIT);
const recentEvents = allRecentEvents.slice(0, RECENT_EVENTS_LIMIT);
const recentEventPoints = recentEvents.reduce((sum, event) => sum + event.points, 0);
const postBySlug = new Map(posts.map((post) => [post.slug, post]));

const categoryInsightsMap = new Map<string, {
  key: string;
  label: string;
  postCount: number;
  featuredCount: number;
  latestDate: string;
}>();

for (const post of posts) {
  const current = categoryInsightsMap.get(post.category) ?? {
    key: post.category,
    label: post.categoryLabel,
    postCount: 0,
    featuredCount: 0,
    latestDate: post.date
  };

  current.postCount += 1;
  if (post.featured) current.featuredCount += 1;
  if (post.date > current.latestDate) current.latestDate = post.date;

  categoryInsightsMap.set(post.category, current);
}

const categoryInsights = [...categoryInsightsMap.values()]
  .sort((a, b) => b.postCount - a.postCount || a.label.localeCompare(b.label))
  .slice(0, CATEGORY_INSIGHTS_LIMIT);
const hiddenTagCount = Math.max(0, tagRecords.length - topTags.length);
const hiddenContributorCount = Math.max(0, totalContributors - topContributors.length);
const faqEntries = [
  {
    question: 'Do I need to be an advanced writer to publish here?',
    answer:
      'No. Draft clarity matters more than perfection. Reviews happen through pull requests, so you can iterate with feedback before your contribution is merged.'
  },
  {
    question: 'What types of improvements are accepted?',
    answer:
      'New tutorials, better explanations, fixes to outdated snippets, and stronger references are all valuable. Small quality upgrades are welcome.'
  },
  {
    question: 'How is contribution impact measured?',
    answer:
      'Accepted pull requests are scored with transparent labels. Your points and accepted PRs appear on public profile and leaderboard pages.'
  },
  {
    question: 'Can I contribute without writing a full new post?',
    answer:
      'Yes. You can refine structure, add examples, improve language, and update technical details in existing posts. Those improvements are tracked too.'
  }
] as const;

const getPostPath = (slug: string): string =>
  `/posts/${slug.split('/').map((segment) => encodeURIComponent(segment)).join('/')}`;
const getHomePagePath = (page: number): string => (page <= 1 ? '/' : `/page/${page}`);

const getPullRequestUrl = (prNumber: number): string =>
  `https://github.com/hajiparvaneh/openblog/pull/${prNumber}`;

const pageDescription =
  'OpenBlog is a free collaborative technical blog where developers publish with pull requests, build a visible GitHub portfolio, and improve hiring reputation.';
const canonicalPath = '/';
const siteUrl = getSiteUrl(Astro.site);
const canonicalUrl = toAbsoluteUrl(canonicalPath, siteUrl);
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'OpenBlog',
    description: pageDescription,
    url: toAbsoluteUrl('/', siteUrl)
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'OpenBlog Home',
    description: pageDescription,
    url: canonicalUrl
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'OpenBlog Top Categories',
    itemListElement: categoryInsights.slice(0, 6).map((category, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: toAbsoluteUrl(getCategoryPath(category.key), siteUrl),
      name: category.label
    }))
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqEntries.map((entry) => ({
      '@type': 'Question',
      name: entry.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: entry.answer
      }
    }))
  }
];
---
<BaseLayout title="OpenBlog | Free Collaborative Blog for GitHub Portfolio Growth" description={pageDescription} canonicalPath={canonicalPath} structuredData={structuredData}>
  <section class="card hero">
    <div class="hero-main">
      <p class="kicker icon-label"><i class="ti ti-news icon-sm" aria-hidden="true"></i>Open source publication</p>
      <h1>Write together and grow your GitHub reputation.</h1>
      <p class="meta">Every accepted pull request improves content and creates visible proof of teamwork, consistency, and technical communication.</p>
      <div class="hero-actions">
        <a class="home-cta" href="/how-to-contribute">
          <i class="ti ti-pencil-plus icon-sm" aria-hidden="true"></i>
          Start contributing
        </a>
        <a class="home-cta home-cta-soft" href="/leaderboard">
          <i class="ti ti-trophy icon-sm" aria-hidden="true"></i>
          View leaderboard
        </a>
      </div>
      <ul class="hero-highlights">
        <li class="hero-highlight"><i class="ti ti-badge-check icon-sm" aria-hidden="true"></i>Editorial reviews through pull requests</li>
        <li class="hero-highlight"><i class="ti ti-certificate icon-sm" aria-hidden="true"></i>Public proof-of-work tied to your GitHub profile</li>
        <li class="hero-highlight"><i class="ti ti-users-group icon-sm" aria-hidden="true"></i>Cross-category collaboration with visible contribution history</li>
      </ul>
    </div>

    <div class="hero-side">
      <p class="kicker icon-label"><i class="ti ti-chart-bar icon-sm" aria-hidden="true"></i>Community snapshot</p>
      <div class="stats">
        <div class="stat">
          <span class="stat-value stat-head"><i class="ti ti-notes icon-sm" aria-hidden="true"></i>{posts.length}</span>
          <span class="stat-label">Published posts</span>
        </div>
        <div class="stat">
          <span class="stat-value stat-head"><i class="ti ti-category icon-sm" aria-hidden="true"></i>{categoryCount}</span>
          <span class="stat-label">Active categories</span>
        </div>
        <div class="stat">
          <span class="stat-value stat-head"><i class="ti ti-users icon-sm" aria-hidden="true"></i>{totalContributors}</span>
          <span class="stat-label">{contributorsStatLabel}</span>
        </div>
        <div class="stat">
          <span class="stat-value stat-head"><i class="ti ti-star-filled icon-sm" aria-hidden="true"></i>{featuredPostCount}</span>
          <span class="stat-label">Featured stories</span>
        </div>
        <div class="stat">
          <span class="stat-value stat-head"><i class="ti ti-tags icon-sm" aria-hidden="true"></i>{tagCount}</span>
          <span class="stat-label">Indexed tags</span>
        </div>
        <div class="stat">
          <span class="stat-value stat-head"><i class="ti ti-sparkles icon-sm" aria-hidden="true"></i>{recentEventPoints}</span>
          <span class="stat-label">Recent points</span>
        </div>
      </div>
      {latestContributors.length > 0 && (
        <div class="hero-side-foot">
          <p class="meta icon-label"><i class="ti ti-users icon-sm" aria-hidden="true"></i>Recently active</p>
          <div class="hero-side-avatars">
            {latestContributors.slice(0, LATEST_CONTRIBUTORS_LIMIT).map((contributor) => (
              <a
                class="hero-side-avatar-link"
                href={getProfilePath(contributor.username)}
                aria-label={`@${contributor.username}`}
                title={`@${contributor.username}`}
              >
                <UserAvatar
                  username={contributor.username}
                  avatarUrl={contributor.avatarUrl}
                  size={64}
                  class="hero-side-avatar"
                  alt=""
                  width={28}
                  height={28}
                />
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <nav class="card home-jump-links" aria-label="Homepage sections">
    <a href="#home-posts"><i class="ti ti-list icon-sm" aria-hidden="true"></i>All stories</a>
    <a href="#home-community"><i class="ti ti-bolt icon-sm" aria-hidden="true"></i>Community pulse</a>
    <a href="#home-faq"><i class="ti ti-help-hexagon icon-sm" aria-hidden="true"></i>Contributor FAQ</a>
  </nav>

  <FeaturedPostsSlider posts={posts} limit={5} class="card" />

  {latestPost ? <LatestPostCard post={latestPost} /> : null}

  {topTags.length > 0 && (
    <Fragment slot="sidebar-extra">
      <p class="kicker icon-label"><i class="ti ti-tags icon-sm" aria-hidden="true"></i>Popular tags</p>
      <nav aria-label="Popular tags">
        <div class="tag-cloud" role="list">
          {topTags.map((tag) => (
            <a role="listitem" class="tag-cloud-item" href={getTagPath(tag.label)}>
              <span>{tag.label}</span>
              <span class="badge">{tag.postCount}</span>
            </a>
          ))}
        </div>
      </nav>
      {hiddenTagCount > 0 ? (
        <p class="meta list-limit-note icon-label">
          <i class="ti ti-tags icon-sm" aria-hidden="true"></i>
          +{hiddenTagCount} more tags
        </p>
      ) : null}
    </Fragment>
  )}

  {remainingPosts.length > 0 ? (
    <section id="home-posts" class="card list paginated-list home-posts-section">
      <div class="section-head section-head-inline">
        <div>
          <p class="kicker icon-label"><i class="ti ti-list icon-sm" aria-hidden="true"></i>Browse all stories</p>
          <h2>Complete post archive</h2>
        </div>
        <p id="home-posts-page-info" class="meta pagination-info">Page {currentPage} of {postsTotalPages} ({remainingPosts.length} posts)</p>
      </div>

      <div class="post-grid">
        {paginatedPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>

      {postsTotalPages > 1 && (
        <nav class="leaderboard-pagination" aria-label="Homepage posts pages">
          <a
            id="home-posts-prev"
            class:list={['page-control', currentPage <= 1 && 'is-disabled']}
            href={getHomePagePath(Math.max(1, currentPage - 1))}
            aria-disabled={currentPage <= 1 ? 'true' : undefined}
          >
            Previous
          </a>
          <ul class="page-links" aria-label="Page numbers">
            {postPageNumbers.map((page) => (
              <li>
                <a class:list={['page-link', page === currentPage && 'is-active']} href={getHomePagePath(page)} aria-current={page === currentPage ? 'page' : undefined}>{page}</a>
              </li>
            ))}
          </ul>
          <a
            id="home-posts-next"
            class:list={['page-control', currentPage >= postsTotalPages && 'is-disabled']}
            href={getHomePagePath(Math.min(postsTotalPages, currentPage + 1))}
            aria-disabled={currentPage >= postsTotalPages ? 'true' : undefined}
          >
            Next
          </a>
        </nav>
      )}
    </section>
  ) : (
    <section id="home-posts" class="card list home-posts-section">
      <p class="kicker icon-label"><i class="ti ti-list icon-sm" aria-hidden="true"></i>Browse all stories</p>
      <article class="home-empty-state">
        <h2>More stories are on the way</h2>
        <p class="meta">Only one post is available right now. More coming soon.</p>
      </article>
    </section>
  )}


  <section id="home-community" class="card home-community">
    <div class="section-head">
      <div>
        <p class="kicker icon-label"><i class="ti ti-bolt icon-sm" aria-hidden="true"></i>Community pulse</p>
        <h2>See what is being improved right now</h2>
      </div>
      <p class="meta">Recent accepted pull requests and active contributors, all visible in public GitHub history.</p>
    </div>

    <div class="community-overview">
      <span class="badge"><i class="ti ti-git-pull-request icon-sm" aria-hidden="true"></i>{recentEvents.length} latest accepted contributions</span>
      <span class="badge"><i class="ti ti-sparkles icon-sm points-icon" aria-hidden="true"></i>{recentEventPoints} points in recent activity</span>
      <span class="badge"><i class="ti ti-users icon-sm" aria-hidden="true"></i>{latestContributors.length} recently active contributors</span>
    </div>

    <div class="community-layout">
      <section class="community-block community-block-primary">
        <h3 class="icon-label"><i class="ti ti-git-pull-request icon-sm" aria-hidden="true"></i>Latest accepted PR activity</h3>
        {recentEvents.length > 0 ? (
          <ul class="home-activity-list">
            {recentEvents.map((event) => {
              const eventPost = postBySlug.get(event.postSlug);
              return (
                <li class="home-activity-item">
                  <a class="user-chip user-link" href={getProfilePath(event.username)}>
                    <UserAvatar username={event.username} avatarUrl={event.userAvatarUrl} size={64} class="avatar-sm" />
                    <span class="user-handle">@{event.username}</span>
                  </a>
                  <span class="meta">opened</span>
                  <a href={getPullRequestUrl(event.prNumber)} target="_blank" rel="noopener noreferrer">PR #{event.prNumber}</a>
                  <span class="meta">for</span>
                  {eventPost ? (
                    <a href={getPostPath(eventPost.slug)}>{eventPost.title}</a>
                  ) : (
                    <span>{event.postSlug}</span>
                  )}
                  <span class="badge points-badge"><i class="ti ti-sparkles icon-sm points-icon" aria-hidden="true"></i>+{event.points}</span>
                </li>
              );
            })}
          </ul>
        ) : (
          <p class="meta">No contribution activity found yet.</p>
        )}
      </section>

      <div class="community-side">
      <section class="community-block">
        <h3 class="icon-label"><i class="ti ti-users icon-sm" aria-hidden="true"></i>{topContributorsTitle}</h3>
        <p class="meta list-limit-note">{topContributorsDescription}</p>
        {topContributors.length > 0 ? (
          <ol class="home-top-contributors">
            {topContributors.map((contributor, index) => (
              <li class="home-top-contributor-item">
                <span class="home-rank">#{index + 1}</span>
                <a class="user-chip user-link" href={getProfilePath(contributor.username)}>
                  <UserAvatar username={contributor.username} avatarUrl={contributor.avatarUrl} size={64} class="avatar-sm" />
                  <span class="user-handle">@{contributor.username}</span>
                </a>
                <span class="badge points-badge"><i class="ti ti-sparkles icon-sm points-icon" aria-hidden="true"></i>{contributor.totalPoints}</span>
              </li>
            ))}
          </ol>
        ) : (
          <p class="meta">{topContributorsEmptyState}</p>
        )}

        <a class="community-link" href="/leaderboard">
          Full leaderboard
          <i class="ti ti-arrow-right icon-sm" aria-hidden="true"></i>
        </a>
        {hiddenContributorCount > 0 ? <p class="meta list-limit-note">+{hiddenContributorCount} {hiddenContributorsLabel}</p> : null}
      </section>

      <section class="community-block">
        <h3 class="icon-label"><i class="ti ti-route icon-sm" aria-hidden="true"></i>How publishing works here</h3>
        <ol class="home-process-list">
          <li><strong>Draft:</strong> Add or improve a post as markdown in the repository.</li>
          <li><strong>Review:</strong> Open a pull request and iterate with feedback.</li>
          <li><strong>Publish:</strong> Merged PR updates the live blog and your public contribution history.</li>
        </ol>
        <a class="community-link" href="/how-to-contribute">
          Contribution guide
          <i class="ti ti-arrow-right icon-sm" aria-hidden="true"></i>
        </a>
      </section>

      {latestContributors.length > 0 && (
        <section class="community-block">
          <h3 class="icon-label"><i class="ti ti-users-group icon-sm" aria-hidden="true"></i>Recently active contributors</h3>
          <ul class="home-latest-contributors">
            {latestContributors.slice(0, LATEST_CONTRIBUTORS_LIMIT).map((contributor) => (
              <li>
                <a class="user-chip user-link" href={getProfilePath(contributor.username)}>
                  <UserAvatar username={contributor.username} avatarUrl={contributor.avatarUrl} size={64} class="avatar-sm" />
                  <span class="user-handle">@{contributor.username}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
      </div>
    </div>
  </section>

  <section id="home-faq" class="card home-faq">
    <div class="section-head">
      <div>
        <p class="kicker icon-label"><i class="ti ti-help-hexagon icon-sm" aria-hidden="true"></i>Contributor FAQ</p>
        <h2>Common questions before your first pull request</h2>
      </div>
      <p class="meta">Short answers for contributors who want to move fast without missing project expectations.</p>
    </div>

    <div class="faq-list">
      {faqEntries.map((entry, index) => (
        <details class="faq-item" open={index === 0}>
          <summary>{entry.question}</summary>
          <p class="meta">{entry.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <script is:inline>
    (function () {
      if (window.location.pathname !== '/') return;
      var params = new URLSearchParams(window.location.search);
      var requestedPage = Number(params.get('page') || '1');
      if (!Number.isFinite(requestedPage) || requestedPage <= 1) return;
      var normalizedPage = Math.floor(requestedPage);
      window.location.replace('/page/' + normalizedPage + window.location.hash);
    })();
  </script>

  <style>
    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
      align-items: start;
      gap: 0.85rem;
    }

    .hero-main h1 {
      margin-bottom: 0.55rem;
    }

    .hero-actions {
      margin-top: 0.9rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
    }

    .home-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      border: 1px solid var(--success);
      border-radius: var(--radius-sm);
      background: var(--success);
      color: #fff;
      font-family: var(--font-main);
      font-size: 0.82rem;
      font-weight: 600;
      line-height: 1;
      padding: 0.5rem 0.7rem;
      text-decoration: none;
    }

    .home-cta:hover {
      color: #fff;
      background: var(--success-strong);
      border-color: var(--success-strong);
    }

    .home-cta-soft {
      border-color: var(--border);
      background: var(--surface);
      color: var(--text);
    }

    .home-cta-soft:hover {
      color: var(--text);
      background: var(--surface-soft);
      border-color: var(--primary);
    }

    .hero-highlights {
      list-style: none;
      margin: 0.85rem 0 0;
      padding: 0;
      display: grid;
      gap: 0.38rem;
    }

    .hero-highlight {
      display: inline-flex;
      align-items: center;
      gap: 0.32rem;
      color: var(--muted);
      font-family: var(--font-main);
      font-size: 0.84rem;
      font-weight: 600;
      line-height: 1.3;
    }

    .hero-side {
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--surface);
      padding: 0.62rem;
      display: grid;
      gap: 0.52rem;
      box-shadow: var(--shadow-xs);
    }

    .hero-side .stats {
      margin-top: 0.45rem;
      gap: 0.45rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-side .stat {
      background: var(--surface);
      padding: 0.52rem;
    }

    .hero-side .stat-value {
      font-size: 1.05rem;
    }

    .hero-side-foot {
      display: grid;
      gap: 0.35rem;
      border-top: 1px solid var(--border);
      padding-top: 0.45rem;
    }

    .hero-side-foot .meta {
      margin: 0;
      font-size: 0.76rem;
    }

    .hero-side-avatars {
      display: flex;
      flex-wrap: wrap;
      gap: 0.28rem;
    }

    .hero-side-avatar-link {
      display: inline-flex;
      border: 1px solid var(--border);
      border-radius: 9999px;
      background: var(--surface-raised);
      padding: 0.08rem;
    }

    .hero-side-avatar {
      width: 1.4rem;
      height: 1.4rem;
      border: 0;
    }

    .hero-side-avatar-link:hover {
      border-color: var(--primary);
    }

    [id^='home-'] {
      scroll-margin-top: 1rem;
    }

    .home-jump-links {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(135px, 1fr));
      gap: 0.45rem;
    }

    .home-jump-links a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.32rem;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--surface);
      color: var(--text);
      font-family: var(--font-main);
      font-size: 0.76rem;
      font-weight: 600;
      line-height: 1;
      padding: 0.3rem 0.5rem;
      text-decoration: none;
    }

    .home-jump-links a:hover {
      border-color: var(--primary);
      background: var(--surface-soft);
    }

    .home-faq {
      display: grid;
      gap: 0.62rem;
    }

    .home-discovery-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
      align-items: stretch;
      gap: 0.85rem;
    }

    .home-discovery-side {
      display: grid;
      gap: 0;
      align-content: stretch;
      height: 100%;
    }

    .home-categories,
    .home-tags {
      height: 100%;
    }

    .home-tags {
      align-content: start;
    }

    .section-head {
      display: grid;
      gap: 0.32rem;
      margin-bottom: 0.55rem;
    }

    .section-head h2 {
      margin: 0;
      font-size: 1.35rem;
    }

    .section-head .meta {
      margin: 0;
      font-size: 0.82rem;
    }

    .section-head-inline {
      display: flex;
      flex-wrap: wrap;
      align-items: end;
      justify-content: space-between;
      gap: 0.5rem;
      margin-bottom: 0;
    }

    .section-head-inline .meta {
      margin-left: auto;
