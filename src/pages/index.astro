---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatPostDate, getCategoryPath, getLatestContributorsForPost, getPosts } from '../lib/openblog';

const posts = getPosts();
const latestPost = posts[0];
const remainingPosts = posts.slice(1);
const categoryCount = new Set(posts.map((post) => post.category)).size;
const latestContributors = latestPost ? getLatestContributorsForPost(latestPost.slug, 5) : [];
const getAvatarUrl = (username: string, avatarUrl?: string | null) =>
  avatarUrl ?? `https://github.com/${username}.png?size=64`;
---
<BaseLayout title="OpenBlog">
  <section class="card hero">
    <p class="kicker icon-label"><i class="ti ti-news icon-sm" aria-hidden="true"></i>Open source publication</p>
    <h1>Write and improve posts together.</h1>
    <p class="meta">Every accepted pull request improves the content and awards points on the public leaderboard.</p>
    <div class="stats">
      <div class="stat">
        <span class="stat-value stat-head"><i class="ti ti-notes icon-sm" aria-hidden="true"></i>{posts.length}</span>
        <span class="stat-label">Published posts</span>
      </div>
      <div class="stat">
        <span class="stat-value stat-head"><i class="ti ti-category icon-sm" aria-hidden="true"></i>{categoryCount}</span>
        <span class="stat-label">Active categories</span>
      </div>
      <div class="stat">
        <span class="stat-value stat-head"><i class="ti ti-git-pull-request icon-sm" aria-hidden="true"></i>PR-based</span>
        <span class="stat-label">Contribution model</span>
      </div>
    </div>
  </section>

  {latestPost ? (
    <section class="card post-card latest-post-card">
      <a class="category-link latest-post-category" href={getCategoryPath(latestPost.category)}>
        <i class="ti ti-category icon-sm" aria-hidden="true"></i>
        {latestPost.categoryLabel}
      </a>
      <p class="kicker icon-label"><i class="ti ti-clock-hour-4 icon-sm" aria-hidden="true"></i>Latest post</p>
      <h2><a href={`/posts/${latestPost.slug}`}>{latestPost.title}</a></h2>
      <p>{latestPost.description}</p>
      <p class="meta meta-inline">
        {latestContributors.length > 0 ? (
          <span class="meta-item latest-post-contributors-inline">
            <span class="latest-post-contributors-list">
              {latestContributors.map((contributor) => (
                <a
                  class="user-chip user-link latest-post-contributor-inline"
                  href={contributor.profileUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`@${contributor.username}`}
                  title={`@${contributor.username}`}
                >
                  <img
                    class="avatar avatar-sm"
                    src={getAvatarUrl(contributor.username, contributor.avatarUrl)}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    width="24"
                    height="24"
                  />
                  <span class="latest-post-contributor-name">@{contributor.username}</span>
                </a>
              ))}
            </span>
          </span>
        ) : null}
        <span class="meta-item"><i class="ti ti-calendar icon-sm" aria-hidden="true"></i>{formatPostDate(latestPost.date)}</span>
      </p>
    </section>
  ) : null}

  {remainingPosts.length > 0 ? (
    <section class="list">
      <p class="kicker icon-label"><i class="ti ti-list icon-sm" aria-hidden="true"></i>Browse all stories</p>
      <div class="post-grid">
        {remainingPosts.map((post) => (
          <article class="card post-card">
            <h2><a href={`/posts/${post.slug}`}>{post.title}</a></h2>
            <p>{post.description}</p>
            <p class="meta meta-inline">
              <span class="meta-item"><i class="ti ti-calendar icon-sm" aria-hidden="true"></i>{formatPostDate(post.date)}</span>
              <span class="meta-item"><i class="ti ti-category icon-sm" aria-hidden="true"></i><a href={getCategoryPath(post.category)}>{post.categoryLabel}</a></span>
            </p>
          </article>
        ))}
      </div>
    </section>
  ) : (
    <section class="list">
      <p class="kicker icon-label"><i class="ti ti-list icon-sm" aria-hidden="true"></i>Browse all stories</p>
      <article class="card">
        <h2>More stories are on the way</h2>
        <p class="meta">Only one post is available right now. More coming soon.</p>
      </article>
    </section>
  )}
</BaseLayout>
