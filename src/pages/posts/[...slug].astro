---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { marked } from 'marked';
import { getPosts, getPostBySlug, getContributorsForPost } from '../../lib/game';

export function getStaticPaths() {
  return getPosts().map((post) => ({ params: { slug: post.slug } }));
}

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join('/') : slugParam ?? '';
const post = getPostBySlug(slug);
if (!post) throw new Error('Post not found');
const contributors = getContributorsForPost(slug);
const html = marked.parse(post.body);
const getAvatarUrl = (username: string, avatarUrl?: string | null) =>
  avatarUrl ?? `https://github.com/${username}.png?size=80`;
const getProfileUrl = (username: string) => `https://github.com/${username}`;
const categoryPath = `/categories/${encodeURIComponent(post.category)}`;
---
<BaseLayout title={`${post.title} | OpenBlog`}>
  <div class="two-column">
    <article class="card">
      <p class="kicker icon-label"><i class="ti ti-home icon-sm" aria-hidden="true"></i><a href="/">Home</a> / <a href={categoryPath}>{post.category}</a></p>
      <h1>{post.title}</h1>
      <p class="meta meta-inline">
        <span class="meta-item"><i class="ti ti-calendar icon-sm" aria-hidden="true"></i>{post.date}</span>
        <span class="meta-item"><i class="ti ti-category icon-sm" aria-hidden="true"></i><a href={categoryPath}>{post.category}</a></span>
      </p>
      <div class="article-content" set:html={html} />
    </article>

    <aside class="card">
      <h2 class="icon-label"><i class="ti ti-users icon-sm" aria-hidden="true"></i>Contributors</h2>
      {contributors.length === 0 ? (
        <p class="meta">No accepted contributions yet.</p>
      ) : (
        <ul class="contributors">
          {contributors.map((contributor) => (
            <li class="contributor-card">
              <a class="user-chip user-link" href={getProfileUrl(contributor.username)} target="_blank" rel="noopener noreferrer">
                <img class="avatar" src={getAvatarUrl(contributor.username, contributor.avatarUrl)} alt={`@${contributor.username} avatar`} loading="lazy" />
                <strong class="user-handle">@{contributor.username}</strong>
              </a>
              <div class="icon-label"><i class="ti ti-award icon-sm" aria-hidden="true"></i>{contributor.totalPoints} points</div>
              <div class="meta icon-label"><i class="ti ti-git-merge icon-sm" aria-hidden="true"></i>{contributor.acceptedPrs} accepted PR{contributor.acceptedPrs > 1 ? 's' : ''} on this post</div>
              <div class="label-row">
                {contributor.labels.map((label) => (
                  <span class="badge">{label}</span>
                ))}
              </div>
            </li>
          ))}
        </ul>
      )}
    </aside>
  </div>
</BaseLayout>
